---
import Icon from './Icon.astro';
import { links } from '../lib/links';

interface Props { variant?: 'light' | 'dark'; compact?: boolean; }
const { variant = 'light', compact = false } = Astro.props;

const wrap = variant === 'dark'
  ? 'border-cream/15 text-cream'
  : 'border-charcoal/10 text-charcoal';
const tile = variant === 'dark'
  ? 'border-cream/15 hover:border-sarang hover:bg-cream/5'
  : 'border-charcoal/10 hover:border-charcoal hover:bg-cream-soft';

const apps = [
  { name: 'GoFood',    href: links.gofood },
  { name: 'GrabFood',  href: links.grabfood },
  { name: 'ShopeeFood',href: links.shopeefood },
];
---

<div class={`${wrap} ${compact ? '' : 'border rounded-2xl p-4'}`}>
  {!compact && <p class="eyebrow mb-3">Atau via ojol</p>}
  <div class="flex flex-wrap gap-2">
    {apps.map((a) => (
      <a
        href={a.href}
        target="_blank"
        rel="noopener"
        class={`group inline-flex items-center gap-2 rounded-full border ${tile} px-4 py-2 transition-colors`}
        aria-label={`Pesan via ${a.name}`}
      >
        <span class="font-display text-sm tracking-tight">{a.name}</span>
        <Icon name="arrow-up-right" size={14} class="opacity-50 group-hover:opacity-100 transition-opacity" />
      </a>
    ))}
  </div>
</div>
