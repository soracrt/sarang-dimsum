---
// Arfan — the chef character. Charcoal line, yellow fill on cream.
// Poses: wave | point | steamer | sleep
interface Props {
  pose?: 'wave' | 'point' | 'steamer' | 'sleep';
  class?: string;
  armClass?: string;
}
const { pose = 'wave', class: className = '', armClass = '' } = Astro.props;
---

{pose === 'wave' && (
  <svg class={className} viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Arfan, the Sarang Dimsum chef, melambai">
    {/* hat */}
    <path d="M30 38c0-12 8-22 22-22s22 9 22 21c8-2 16 4 16 13 0 7-6 12-13 12H27c-7 0-13-5-13-12 0-9 8-15 16-12z" fill="#FAF6EE" stroke="#1F1B17" stroke-width="3"/>
    <path d="M28 62h48v8H28z" fill="#1F1B17"/>
    {/* face */}
    <ellipse cx="52" cy="84" rx="22" ry="20" fill="#FAF6EE" stroke="#1F1B17" stroke-width="3"/>
    {/* eyes */}
    <circle cx="44" cy="82" r="2.2" fill="#1F1B17"/>
    <circle cx="60" cy="82" r="2.2" fill="#1F1B17"/>
    {/* mustache */}
    <path d="M42 90c3 3 7 3 10 1 3 2 7 2 10-1" stroke="#1F1B17" stroke-width="2.5" stroke-linecap="round" fill="none"/>
    {/* smile */}
    <path d="M46 96c2 3 10 3 12 0" stroke="#1F1B17" stroke-width="2.2" stroke-linecap="round" fill="none"/>
    {/* body / apron */}
    <path d="M30 110c0-6 10-10 22-10s22 4 22 10v22H30z" fill="#F4C430" stroke="#1F1B17" stroke-width="3"/>
    <path d="M52 100v32" stroke="#1F1B17" stroke-width="2"/>
    {/* static arm */}
    <path d="M30 112c-6 2-12 8-12 16" stroke="#1F1B17" stroke-width="3" stroke-linecap="round" fill="none"/>
    {/* waving arm */}
    <g class={`arfan-arm ${armClass}`}>
      <path d="M74 112c10-2 18-12 22-26" stroke="#1F1B17" stroke-width="3" stroke-linecap="round" fill="none"/>
      <circle cx="98" cy="84" r="5" fill="#FAF6EE" stroke="#1F1B17" stroke-width="2.5"/>
    </g>
  </svg>
)}

{pose === 'point' && (
  <svg class={className} viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Arfan menunjuk menu">
    <path d="M30 38c0-12 8-22 22-22s22 9 22 21c8-2 16 4 16 13 0 7-6 12-13 12H27c-7 0-13-5-13-12 0-9 8-15 16-12z" fill="#FAF6EE" stroke="#1F1B17" stroke-width="3"/>
    <path d="M28 62h48v8H28z" fill="#1F1B17"/>
    <ellipse cx="52" cy="84" rx="22" ry="20" fill="#FAF6EE" stroke="#1F1B17" stroke-width="3"/>
    <circle cx="44" cy="82" r="2.2" fill="#1F1B17"/>
    <circle cx="60" cy="82" r="2.2" fill="#1F1B17"/>
    <path d="M42 90c3 3 7 3 10 1 3 2 7 2 10-1" stroke="#1F1B17" stroke-width="2.5" stroke-linecap="round" fill="none"/>
    <path d="M46 96c3 2 9 2 12 0" stroke="#1F1B17" stroke-width="2.2" stroke-linecap="round" fill="none"/>
    <path d="M30 110c0-6 10-10 22-10s22 4 22 10v22H30z" fill="#F4C430" stroke="#1F1B17" stroke-width="3"/>
    <path d="M52 100v32" stroke="#1F1B17" stroke-width="2"/>
    <path d="M30 112c-6 2-12 8-12 16" stroke="#1F1B17" stroke-width="3" stroke-linecap="round" fill="none"/>
    {/* pointing arm */}
    <path d="M74 116c12 0 22 4 30 8" stroke="#1F1B17" stroke-width="3" stroke-linecap="round" fill="none"/>
    <path d="M104 124l8 2-2-6" stroke="#1F1B17" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
)}

{pose === 'steamer' && (
  <svg class={className} viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Arfan memegang steling bambu">
    <path d="M40 38c0-12 8-22 22-22s22 9 22 21c8-2 16 4 16 13 0 7-6 12-13 12H37c-7 0-13-5-13-12 0-9 8-15 16-12z" fill="#FAF6EE" stroke="#1F1B17" stroke-width="3"/>
    <path d="M38 62h48v8H38z" fill="#1F1B17"/>
    <ellipse cx="62" cy="84" rx="22" ry="20" fill="#FAF6EE" stroke="#1F1B17" stroke-width="3"/>
    <circle cx="54" cy="82" r="2.2" fill="#1F1B17"/>
    <circle cx="70" cy="82" r="2.2" fill="#1F1B17"/>
    <path d="M52 90c3 3 7 3 10 1 3 2 7 2 10-1" stroke="#1F1B17" stroke-width="2.5" stroke-linecap="round" fill="none"/>
    <path d="M56 96c3 2 9 2 12 0" stroke="#1F1B17" stroke-width="2.2" stroke-linecap="round" fill="none"/>
    <path d="M40 112c0-6 10-10 22-10s22 4 22 10v22H40z" fill="#F4C430" stroke="#1F1B17" stroke-width="3"/>
    <path d="M62 102v32" stroke="#1F1B17" stroke-width="2"/>
    {/* arms forward holding steamer */}
    <path d="M40 116c-2 2-2 8 4 10" stroke="#1F1B17" stroke-width="3" stroke-linecap="round" fill="none"/>
    <path d="M84 116c2 2 2 8-4 10" stroke="#1F1B17" stroke-width="3" stroke-linecap="round" fill="none"/>
    {/* steamer */}
    <ellipse cx="62" cy="126" rx="26" ry="6" fill="#E9DFC7" stroke="#1F1B17" stroke-width="2.5"/>
    <rect x="36" y="120" width="52" height="8" rx="2" fill="#F3ECDD" stroke="#1F1B17" stroke-width="2.5"/>
    {/* steam */}
    <path d="M54 56c2-4-2-6 0-10M62 54c2-4-2-6 0-10M70 56c2-4-2-6 0-10" stroke="#1F1B17" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.6"/>
  </svg>
)}

{pose === 'sleep' && (
  <svg class={className} viewBox="0 0 140 100" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Arfan tidur">
    {/* z's */}
    <text x="92" y="22" font-family="Fraunces, serif" font-size="14" font-weight="600" fill="#1F1B17" opacity="0.6">z</text>
    <text x="100" y="34" font-family="Fraunces, serif" font-size="18" font-weight="600" fill="#1F1B17" opacity="0.5">z</text>
    <text x="110" y="50" font-family="Fraunces, serif" font-size="22" font-weight="600" fill="#1F1B17" opacity="0.4">z</text>
    {/* hat (lying) */}
    <path d="M30 62c0-8 6-14 14-14s14 5 14 13c5-1 10 3 10 8 0 5-4 8-9 8H26c-5 0-9-3-9-8 0-5 5-10 10-8z" fill="#FAF6EE" stroke="#1F1B17" stroke-width="2.5"/>
    {/* body curled */}
    <path d="M58 80c10 0 24 2 30 8H26c4-6 18-8 32-8z" fill="#F4C430" stroke="#1F1B17" stroke-width="2.5"/>
    {/* face — eyes closed */}
    <path d="M40 76c2-1 4-1 6 0M50 76c2-1 4-1 6 0" stroke="#1F1B17" stroke-width="2" stroke-linecap="round" fill="none"/>
  </svg>
)}
