---
import Wordmark from './Wordmark.astro';
import Icon from './Icon.astro';
import { links } from '../lib/links';

const nav = [
  { href: '/menu', label: 'Menu' },
  { href: '/lokasi', label: 'Lokasi' },
  { href: '/sarangers', label: 'Sarangers' },
  { href: '/sewa-steling', label: 'Sewa Steling' },
  { href: '/tentang', label: 'Tentang' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 bg-cream/80 backdrop-blur-md border-b border-charcoal/8">
  <div class="mx-auto max-w-6xl px-5 md:px-8 h-16 flex items-center justify-between gap-6">
    <a href="/" aria-label="Sarang Dimsum — beranda" class="block shrink-0">
      <Wordmark class="h-9 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm">
      {nav.map((n) => (
        <a
          href={n.href}
          class={`relative transition-colors hover:text-charcoal ${path === n.href ? 'text-charcoal' : 'text-charcoal-mute'}`}
        >
          {n.label}
          {path === n.href && <span class="absolute -bottom-[22px] left-0 right-0 h-px bg-charcoal"></span>}
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-4 py-2 text-sm hover:bg-charcoal-soft transition-colors">
        Pesan
        <Icon name="arrow-up-right" size={14}/>
      </a>
    </div>

    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 -mr-2 select-none text-charcoal" aria-label="Buka menu">
        <Icon name="menu" size={22}/>
      </summary>
      <div class="absolute right-0 top-12 w-60 rounded-2xl bg-cream border border-charcoal/10 shadow-xl p-2">
        {nav.map((n) => (
          <a href={n.href} class="block px-4 py-3 rounded-xl hover:bg-cream-soft text-charcoal">{n.label}</a>
        ))}
        <a href={links.waOrder} target="_blank" rel="noopener" class="mt-1 block px-4 py-3 rounded-xl bg-charcoal text-cream text-center">Pesan via WhatsApp</a>
      </div>
    </details>
  </div>
</header>
