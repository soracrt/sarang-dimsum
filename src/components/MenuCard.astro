---
import { monogram } from '../data/menu';

interface Props {
  name: string;
  desc?: string;
  price: number;
  badge?: string;
  category?: 'kukus' | 'goreng' | 'mie' | 'minuman' | 'paket';
}
const { name, desc, price, badge, category = 'kukus' } = Astro.props;
const formatted = new Intl.NumberFormat('id-ID').format(price);
const mark = monogram(name);

// per-category tonal accent for the monogram tile — all warm, all in palette
const tones: Record<string, string> = {
  kukus:   'from-cream-deep to-cream-soft',
  goreng:  'from-sarang/30 to-cream-deep',
  mie:     'from-cream-deep to-cream',
  minuman: 'from-cream-soft to-cream-deep',
  paket:   'from-charcoal/85 to-charcoal text-cream',
};
const tone = tones[category] || tones.kukus;
const isPaket = category === 'paket';
---

<article class="group relative rounded-2xl border border-charcoal/10 bg-cream hover:border-charcoal/25 hover:shadow-[0_12px_40px_-20px_rgba(20,17,13,0.4)] transition-all duration-300">
  <div class="p-5 flex gap-5 items-start">
    <div class={`shrink-0 w-16 h-16 rounded-xl bg-gradient-to-br ${tone} flex items-center justify-center font-display text-xl tracking-tight`}>
      <span class={isPaket ? 'text-cream' : 'text-charcoal'}>{mark}</span>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-4">
        <h3 class="font-display text-lg leading-tight text-charcoal">{name}</h3>
        <div class="text-right shrink-0">
          <div class="eyebrow">IDR</div>
          <div class="font-display text-lg tabular text-charcoal -mt-0.5">{formatted}</div>
        </div>
      </div>
      {desc && <p class="text-sm text-charcoal-mute mt-1.5 leading-snug">{desc}</p>}
      {badge && (
        <span class="inline-block mt-3 text-[10px] uppercase tracking-[0.18em] px-2 py-0.5 rounded-full border border-charcoal/15 text-charcoal-soft">
          {badge}
        </span>
      )}
    </div>
  </div>
</article>
