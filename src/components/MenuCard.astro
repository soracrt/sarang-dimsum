---
import { monogram } from '../data/menu';

interface Props {
  name: string;
  desc?: string;
  price: number;
  badge?: string;
  category?: 'kukus' | 'goreng' | 'mie' | 'minuman' | 'paket';
}
const { name, desc, price, badge, category = 'kukus' } = Astro.props;
const formatted = new Intl.NumberFormat('id-ID').format(price);
const mark = monogram(name);

const tones: Record<string, string> = {
  kukus:   'from-cream-deep via-cream-soft to-cream',
  goreng:  'from-sarang/40 via-sarang/15 to-cream-soft',
  mie:     'from-cream-deep to-cream',
  minuman: 'from-cream-soft to-cream-deep',
  paket:   'from-charcoal/90 to-charcoal',
};
const tone = tones[category] || tones.kukus;
const dark = category === 'paket';
---

<article class="group relative rounded-2xl bg-cream border border-charcoal/10 overflow-hidden hover:border-charcoal/30 hover:-translate-y-0.5 hover:shadow-[0_18px_36px_-18px_rgba(20,17,13,0.35)] transition-all duration-300">
  {/* PHOTO / HERO TILE — square, photo placeholder for now */}
  <div class={`relative aspect-[4/3] bg-gradient-to-br ${tone} overflow-hidden`}>
    <div class={`absolute inset-0 grid place-items-center font-display-x ${dark ? 'text-cream/25' : 'text-charcoal/15'}`} style="font-size: 9rem; line-height: 1;">
      {mark}
    </div>
    {badge && (
      <span class="absolute top-3 left-3 inline-block text-[10px] uppercase tracking-[0.2em] px-2.5 py-1 rounded-full bg-charcoal text-cream font-medium">
        {badge}
      </span>
    )}
    {/* TODO(owner): swap gradient + monogram for real product photo */}
  </div>

  {/* INFO */}
  <div class="px-5 pt-4 pb-5">
    <h3 class="font-display-x text-2xl text-charcoal leading-none uppercase">{name}</h3>
    <div class="mt-2.5 flex items-end justify-between gap-3">
      <p class="text-sm text-charcoal-mute leading-snug flex-1">{desc || 'Halal · porsi pas berdua.'}</p>
      <p class="font-display-x text-2xl tabular text-charcoal leading-none whitespace-nowrap">
        <span class="text-sm tracking-[0.18em] text-charcoal-mute mr-1">RP</span>{formatted}
      </p>
    </div>
  </div>
</article>
