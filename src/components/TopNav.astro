---
import { links } from '../lib/links';

interface Props {
  variant?: 'red' | 'cream' | 'charcoal';
}
const { variant = 'red' } = Astro.props;

// solid backgrounds (not /80) so sticky nav stays legible over any section
const palette = {
  red:      { bg: 'bg-red-deep',  text: 'text-cream',    accent: 'text-sarang',  link: 'text-cream',    cta: 'btn btn-sarang' },
  cream:    { bg: 'bg-cream',     text: 'text-charcoal', accent: 'text-red',     link: 'text-charcoal', cta: 'btn btn-charcoal' },
  charcoal: { bg: 'bg-charcoal',  text: 'text-cream',    accent: 'text-sarang',  link: 'text-cream',    cta: 'btn btn-sarang' },
}[variant];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const nav = [
  { href: '/menu',         label: 'Menu' },
  { href: '/lokasi',       label: 'Lokasi' },
  { href: '/sewa-steling', label: 'Sewa Steling' },
  { href: '/tentang',      label: 'Tentang' },
];
---

<div class={`nav-sticky ${palette.bg} ${palette.text}`}>
  <div class="shell px-5 md:px-10 py-4 flex items-center justify-between">
    <a href="/" class={`font-display-x text-2xl md:text-3xl uppercase tracking-tight leading-none flex items-baseline gap-1 ${palette.link}`}>
      Sarang<span class={`${palette.accent} text-3xl md:text-4xl leading-none translate-y-1`}>*</span>
    </a>

    <nav class="hidden md:flex gap-9 text-sm uppercase tracking-[0.2em] font-semibold">
      {nav.map((n) => (
        <a
          href={n.href}
          class={`transition-colors ${path === n.href ? palette.accent : `${palette.link} opacity-80 hover:opacity-100`}`}
        >
          {n.label}
        </a>
      ))}
    </nav>

    <a href={links.waOrder} target="_blank" rel="noopener" class={`hidden md:inline-flex ${palette.cta}`}>
      Pesan WA
    </a>

    {/* mobile menu */}
    <details class="md:hidden relative">
      <summary class={`list-none cursor-pointer p-2 -mr-2 select-none ${palette.text}`} aria-label="Buka menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </summary>
      <div class={`absolute right-0 top-12 w-64 ${variant === 'cream' ? 'bg-cream border border-charcoal/15' : variant === 'charcoal' ? 'bg-charcoal border border-cream/15' : 'bg-red-deep border border-cream/15'} p-2 z-50 shadow-2xl`}>
        {nav.map((n) => (
          <a href={n.href} class={`block px-4 py-3 ${palette.link} text-sm uppercase tracking-[0.18em] font-semibold`}>{n.label}</a>
        ))}
        <a href={links.waOrder} target="_blank" rel="noopener" class={`mt-1 block ${palette.cta} w-full`}>Pesan via WA</a>
      </div>
    </details>
  </div>
</div>
