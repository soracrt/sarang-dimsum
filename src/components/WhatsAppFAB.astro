---
import { links } from '../lib/links';
---

<a
  href={links.waOrder}
  target="_blank"
  rel="noopener"
  aria-label="Pesan via WhatsApp"
  class="group fixed bottom-5 right-5 md:bottom-7 md:right-7 z-50 inline-flex items-center gap-2.5 rounded-full bg-sarang text-charcoal pl-3 pr-5 py-2.5 shadow-[0_18px_40px_-10px_rgba(20,17,13,0.45)] ring-2 ring-charcoal hover:bg-[#FFD45F] hover:translate-y-[-2px] active:translate-y-0 transition-all duration-200"
>
  <span class="grid place-items-center w-9 h-9 rounded-full bg-charcoal text-sarang">
    {/* Inline WhatsApp glyph — owns its own color, doesn't depend on Icon component */}
