---
import Icon from './Icon.astro';
import { links } from '../lib/links';
---

<a
  href={links.waOrder}
  target="_blank"
  rel="noopener"
  aria-label="Pesan via WhatsApp"
  class="fixed bottom-5 right-5 md:bottom-7 md:right-7 z-50 inline-flex items-center gap-2.5 rounded-full bg-charcoal text-cream pl-4 pr-5 py-3 shadow-[0_18px_40px_-12px_rgba(20,17,13,0.55)] hover:bg-charcoal-soft hover:translate-y-[-2px] active:translate-y-0 transition-all"
>
  <span class="grid place-items-center w-7 h-7 rounded-full bg-sarang text-charcoal">
    <Icon name="message-circle" size={15} strokeWidth={2.2}/>
  </span>
  <span class="text-sm font-medium">Pesan</span>
</a>
