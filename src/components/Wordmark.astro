---
// Reconstructed Sarang Dimsum wordmark — typographic, with Arfan perched on the "A".
// Demo asset; original logo from owner replaces this in production.
interface Props {
  class?: string;
  inverse?: boolean;
}
const { class: className = '', inverse = false } = Astro.props;
const fg = inverse ? '#F8F2E5' : '#14110D';
const accent = '#F0B429';
---

<svg class={className} viewBox="0 0 200 56" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Sarang Dimsum">
  {/* tiny chef perched above the 'A' */}
  <g transform="translate(53 0)">
    <path d="M2 12c0-6 4-11 11-11s11 5 11 10c4-1 8 2 8 6 0 3-3 5-6 5H1c-3 0-5-2-5-5 0-4 4-7 7-6z" fill={accent} stroke={fg} stroke-width="1.2"/>
    <circle cx="9" cy="14" r="1" fill={fg}/>
    <circle cx="17" cy="14" r="1" fill={fg}/>
  </g>

  <text x="0" y="36" font-family="Fraunces, serif" font-size="28" font-weight="600" fill={fg} letter-spacing="-0.02em">Sarang</text>
  <text x="0" y="52" font-family="Inter, sans-serif" font-size="10" font-weight="500" fill={fg} letter-spacing="0.32em" opacity="0.7">DIMSUM</text>
</svg>
