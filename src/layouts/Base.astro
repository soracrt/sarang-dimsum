---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFAB from '../components/WhatsAppFAB.astro';

interface Props {
  title?: string;
  description?: string;
  hideHeader?: boolean;
}
const {
  title = 'Sarang Dimsum — Dimsum hangat, harga dompetan, halal',
  description = 'Dimsum halal di Tiban, Batam. Banyak varian, harga dompetan, ramah keluarga. Pesan via WhatsApp atau ojol favoritmu.',
  hideHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FAF6EE" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="id_ID" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Caveat:wght@500;700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-cream text-charcoal min-h-dvh flex flex-col">
    {!hideHeader && <Header />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppFAB />
    <div id="custom-scrollbar" aria-hidden="true"><div class="thumb"></div></div>
    <script is:inline>
      (function () {
        const init = () => {
          // ===== nav scroll-hide =====
          const navs = document.querySelectorAll('.nav-sticky');
          let lastY = window.scrollY;
          const NAV_THRESHOLD = 6;

          // ===== custom scrollbar =====
          const bar = document.getElementById('custom-scrollbar');
          const thumb = bar && bar.querySelector('.thumb');
          if (!thumb) return;

          const parseRGB = (str) => {
            const m = str && str.match(/rgba?\(([^)]+)\)/);
            if (!m) return null;
            const p = m[1].split(',').map((s) => parseFloat(s.trim()));
            return { r: p[0], g: p[1], b: p[2], a: p[3] === undefined ? 1 : p[3] };
          };
          const luminance = (c) => (0.2126 * c.r + 0.7152 * c.g + 0.0722 * c.b) / 255;

          const sampleBg = (x, y) => {
            const prev = thumb.style.pointerEvents;
            thumb.style.pointerEvents = 'none';
            let el = document.elementFromPoint(x, y);
            thumb.style.pointerEvents = prev;
            while (el) {
              if (el.id === 'custom-scrollbar' || el.classList?.contains('thumb')) {
                el = el.parentElement; continue;
              }
              const bg = getComputedStyle(el).backgroundColor;
              const rgb = parseRGB(bg);
              if (rgb && rgb.a > 0.05) return rgb;
              el = el.parentElement;
            }
            return null;
          };

          let ticking = false;
          let hideTimer = null;

          const update = () => {
            const y = Math.max(0, window.scrollY);
            const vh = window.innerHeight;
            const docH = document.documentElement.scrollHeight;
            const trackH = vh;

            // nav hide/show
            if (navs.length) {
              const delta = y - lastY;
              if (Math.abs(delta) > NAV_THRESHOLD) {
                const hide = delta > 0 && y > 80;
                navs.forEach((n) => n.classList.toggle('is-hidden', hide));
                lastY = y;
              }
            }

            // thumb size + position
            const ratio = vh / docH;
            if (ratio >= 1) {
              bar.classList.remove('is-visible');
              ticking = false;
              return;
            }
            const thumbH = Math.max(32, ratio * trackH);
            const maxTop = trackH - thumbH;
            const top = (docH - vh) > 0 ? (y / (docH - vh)) * maxTop : 0;
            thumb.style.height = thumbH + 'px';
            thumb.style.transform = 'translateY(' + top + 'px)';

            bar.classList.add('is-visible');
            clearTimeout(hideTimer);
            hideTimer = setTimeout(() => bar.classList.remove('is-visible'), 900);

            // adapt color to bg under thumb center
            const rect = thumb.getBoundingClientRect();
            const sampleX = rect.left + rect.width / 2;
            const sampleY = rect.top + rect.height / 2;
            const rgb = sampleBg(sampleX, sampleY);
            if (rgb) {
              const isDark = luminance(rgb) < 0.5;
              thumb.classList.toggle('is-light', isDark);
              thumb.classList.toggle('is-dark', !isDark);
            }

            ticking = false;
          };

          const request = () => {
            if (!ticking) { requestAnimationFrame(update); ticking = true; }
          };

          window.addEventListener('scroll', request, { passive: true });
          window.addEventListener('resize', request);
          update();

          // ===== drag-to-scroll =====
          let dragging = false;
          let dragStartY = 0;
          let dragStartScroll = 0;
          thumb.addEventListener('pointerdown', (e) => {
            dragging = true;
            dragStartY = e.clientY;
            dragStartScroll = window.scrollY;
            thumb.setPointerCapture(e.pointerId);
            e.preventDefault();
          });
          thumb.addEventListener('pointermove', (e) => {
            if (!dragging) return;
            const vh = window.innerHeight;
            const docH = document.documentElement.scrollHeight;
            const trackH = vh;
            const ratio = vh / docH;
            const thumbH = Math.max(32, ratio * trackH);
            const maxTop = trackH - thumbH;
            const dy = e.clientY - dragStartY;
            const scrollDelta = (dy / maxTop) * (docH - vh);
            window.scrollTo({ top: dragStartScroll + scrollDelta, behavior: 'instant' });
          });
          thumb.addEventListener('pointerup', (e) => {
            dragging = false;
            try { thumb.releasePointerCapture(e.pointerId); } catch {}
          });
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else { init(); }
      })();
    </script>
  </body>
</html>
