---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import AggregatorStrip from '../components/AggregatorStrip.astro';
import MenuCard from '../components/MenuCard.astro';
import ArfanWave from '../components/ArfanWave.astro';
import { menu } from '../data/menu';
import { links } from '../lib/links';

const heroItems = menu.filter((m) => m.hero).slice(0, 6);
---

<Base>
  <ArfanWave />

  {/* HERO */}
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 md:px-8 pt-12 md:pt-20 pb-16 grid md:grid-cols-[1.3fr_1fr] gap-10 items-center">
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.2em] text-charcoal-mute mb-5">Halal · Tiban, Batam</span>
        <h1 class="font-display text-4xl md:text-5xl leading-[1.05] text-charcoal">
          Dimsum hangat, harga dompetan —
          <span class="italic text-sarang-deep">buat seisi rumah.</span>
        </h1>
        <p class="mt-5 text-lg text-charcoal-soft max-w-xl">
          Halal, banyak varian, ramah keluarga. Dari dapur kecil di Tiban, langsung ke meja kamu — atau lewat ojol favoritmu.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/menu" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-6 py-3 font-medium hover:bg-charcoal-soft transition-colors">
            Lihat Menu
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-sarang text-charcoal px-6 py-3 font-medium hover:bg-sarang-deep transition-colors">
            Pesan via WhatsApp
          </a>
        </div>

        <div class="mt-8 max-w-md">
          <AggregatorStrip />
        </div>

        <p class="mt-5 text-sm text-charcoal-mute">atau scroll buat lihat menunya 👇</p>
      </div>

      <div class="hidden md:flex justify-end">
        <Arfan pose="wave" class="w-72 h-auto" />
      </div>
    </div>
  </section>

  {/* TIGA JANJI */}
  <section class="bg-cream-soft border-y border-charcoal/10">
    <div class="mx-auto max-w-6xl px-5 md:px-8 py-16 grid gap-8 md:grid-cols-3">
      {[
        { icon: '🕌', t: 'Halal & higienis', d: 'Bahan dipilih, dapur terjaga. Aman buat keluarga.' },
        { icon: '🥟', t: 'Banyak varian, harga dompetan', d: 'Mulai dari Rp 14rb. Ada yang kukus, goreng, sampai mie.' },
        { icon: '👨‍👩‍👧', t: 'Ramah keluarga', d: 'Porsi enak buat berdua, paket hemat buat seisi rumah.' },
      ].map((j) => (
        <div class="flex gap-4">
          <div class="shrink-0 w-12 h-12 rounded-xl bg-sarang/40 flex items-center justify-center text-2xl">{j.icon}</div>
          <div>
            <h3 class="font-display text-xl">{j.t}</h3>
            <p class="text-charcoal-mute mt-1">{j.d}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* MENU TEASER */}
  <section class="mx-auto max-w-6xl px-5 md:px-8 py-20">
    <div class="flex items-end justify-between gap-6 mb-8 flex-wrap">
      <div>
        <span class="text-xs uppercase tracking-[0.2em] text-charcoal-mute">Yang paling dicari</span>
        <h2 class="font-display text-3xl md:text-4xl mt-2">Andalan dari dapur Sarang</h2>
      </div>
      <a href="/menu" class="inline-flex items-center gap-2 text-charcoal-soft hover:text-sarang-deep font-medium">
        Lihat semua menu
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {heroItems.map((m) => <MenuCard {...m} />)}
    </div>
  </section>

  {/* SEWA STELING */}
  <section class="bg-charcoal text-cream relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 md:px-8 py-20 grid md:grid-cols-[1fr_auto] gap-10 items-center">
      <div class="max-w-2xl">
        <span class="inline-block text-xs uppercase tracking-[0.2em] text-sarang mb-4">Untuk pemilik warung</span>
        <h2 class="font-display text-3xl md:text-4xl text-cream leading-tight">
          Punya warung? <span class="italic text-sarang">Sewa stelingnya, jualan dimsumnya.</span>
        </h2>
        <p class="mt-5 text-cream/80 text-lg">
          Kami sediakan steling, dimsumnya, dan pelatihan singkat. Kamu fokus jualan. Cocok buat warung kopi, ruko, food court, atau toko ramai yang mau nambah lini halal cepat saji.
        </p>
        <ul class="mt-6 space-y-2 text-cream/80">
          <li class="flex gap-3"><span class="text-sarang">✓</span> Skema sewa fleksibel — mulai dari per bulan.</li>
          <li class="flex gap-3"><span class="text-sarang">✓</span> Supply dimsum rutin, harga mitra.</li>
          <li class="flex gap-3"><span class="text-sarang">✓</span> Pelatihan + standar kebersihan.</li>
        </ul>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/sewa-steling" class="inline-flex items-center gap-2 rounded-full bg-sarang text-charcoal px-6 py-3 font-medium hover:bg-sarang-deep transition-colors">
            Lihat skema lengkap
          </a>
          <a href={links.waReseller} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-cream/30 px-6 py-3 font-medium hover:bg-cream/10 transition-colors">
            Tanya via WhatsApp
          </a>
        </div>
      </div>
      <Arfan pose="steamer" class="hidden md:block w-72 h-auto" />
    </div>
  </section>

  {/* SARANGERS */}
  <section class="mx-auto max-w-6xl px-5 md:px-8 py-20">
    <div class="text-center max-w-2xl mx-auto">
      <span class="text-xs uppercase tracking-[0.2em] text-charcoal-mute">Komunitas pelanggan</span>
      <h2 class="font-display text-3xl md:text-4xl mt-2">#Sarangers</h2>
      <p class="mt-3 text-charcoal-soft">
        Tag <a href={links.ig} class="text-sarang-deep underline underline-offset-4">@dimsum_sarang</a> di IG kamu — biar masuk dinding ini.
      </p>
    </div>
    <div class="mt-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      {Array.from({ length: 6 }).map((_, i) => (
        <a href={links.ig} class="aspect-square rounded-2xl bg-cream-soft border border-charcoal/10 hover:border-sarang flex items-center justify-center text-3xl transition-colors" aria-label={`Foto Sarangers #${i + 1}`}>
          {['🥟','🦐','🍜','🥯','🍗','🌯'][i]}
        </a>
      ))}
    </div>
    {/* TODO(owner): wire up real IG embed or scrape feed */}
  </section>

  {/* LOKASI & JAM */}
  <section class="bg-cream-soft border-y border-charcoal/10">
    <div class="mx-auto max-w-6xl px-5 md:px-8 py-16 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <span class="text-xs uppercase tracking-[0.2em] text-charcoal-mute">Mampir langsung</span>
        <h2 class="font-display text-3xl md:text-4xl mt-2">Jalan Ciptaland, Tiban — Batam</h2>
        <p class="mt-4 text-charcoal-soft text-lg">
          Buka tiap hari, <strong>jam 10:00 sampai tengah malam</strong>. Pas buat sarapan siang sampai begadang malam.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={links.maps} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-6 py-3 font-medium hover:bg-charcoal-soft transition-colors">
            Buka di Google Maps
          </a>
          <a href="/lokasi" class="inline-flex items-center gap-2 rounded-full border border-charcoal/20 px-6 py-3 font-medium hover:bg-cream transition-colors">
            Detail lokasi
          </a>
        </div>
      </div>
      <div class="aspect-[4/3] rounded-3xl bg-cream-deep border border-charcoal/10 flex items-center justify-center text-charcoal-mute">
        {/* TODO(owner): embed real Google Maps iframe with exact pin */}
        <div class="text-center px-6">
          <div class="text-5xl">📍</div>
          <p class="mt-3 font-medium text-charcoal">Jalan Ciptaland, Tiban</p>
          <p class="text-sm">Batam, Kepulauan Riau</p>
        </div>
      </div>
    </div>
  </section>
</Base>
