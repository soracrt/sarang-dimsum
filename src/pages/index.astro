---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import Icon from '../components/Icon.astro';
import AggregatorStrip from '../components/AggregatorStrip.astro';
import MenuCard from '../components/MenuCard.astro';
import { menu } from '../data/menu';
import { links } from '../lib/links';

const heroItems = menu.filter((m) => m.hero).slice(0, 6);
---

<Base>
  {/* RED HERO — deep auspicious red, massive uppercase */}
  <section class="relative bg-red text-cream overflow-hidden">
    {/* utility top bar */}
    <div class="relative border-b border-cream/15">
      <div class="mx-auto max-w-7xl px-5 md:px-8 h-12 flex items-center justify-between text-[0.6875rem] tracking-[0.22em] uppercase text-cream/75">
        <div class="flex items-center gap-6 md:gap-8">
          <a href="/menu" class="hover:text-cream transition-colors">Menu</a>
          <a href="/tentang" class="hover:text-cream transition-colors">Tentang</a>
          <a href="/sarangers" class="hover:text-cream transition-colors hidden sm:inline">Sarangers</a>
          <a href="/sewa-steling" class="hover:text-cream transition-colors hidden sm:inline">Sewa Steling</a>
        </div>
        <div class="hidden md:flex items-center gap-6 text-cream/60">
          <span>Tiban — Batam</span>
          <span class="text-cream/30">·</span>
          <span class="tabular">10:00 — 00:00</span>
        </div>
        <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-cream/40 px-4 py-1.5 hover:bg-cream hover:text-red-deep transition-colors">
          Pesan Sekarang
        </a>
      </div>
    </div>

    {/* hero body */}
    <div class="relative mx-auto max-w-7xl px-5 md:px-8 pt-10 md:pt-14 pb-20 md:pb-28">
      <div class="grid md:grid-cols-[1.15fr_0.85fr] gap-8 md:gap-12 items-center">
        {/* LEFT — massive headline */}
        <div>
          <h1 class="font-display-x text-[5rem] sm:text-[7rem] md:text-[9.5rem] leading-[0.86] text-cream uppercase">
            Dimsum<br/>
            Hangat,<br/>
            Harga<br/>
            Dompetan.
          </h1>

          <p class="mt-8 text-lg md:text-xl text-cream/80 max-w-xl leading-relaxed">
            Halal, banyak varian, ramah keluarga. Dari dapur kecil di Tiban — langsung ke meja kamu, atau lewat ojol favoritmu.
          </p>

          <div class="mt-9 flex flex-wrap gap-3">
            <a href="/menu" class="group inline-flex items-center gap-2 rounded-full bg-sarang text-charcoal px-7 py-3.5 font-medium hover:bg-cream transition-colors">
              Lihat Menu
              <Icon name="arrow-right" size={16} class="group-hover:translate-x-0.5 transition-transform"/>
            </a>
            <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-cream/40 px-7 py-3.5 font-medium hover:bg-cream/10 transition-colors">
              <Icon name="message-circle" size={16}/>
              Pesan via WhatsApp
            </a>
          </div>
        </div>

        {/* RIGHT — hero food card */}
        <div class="relative">
          <div class="relative aspect-[4/5] rounded-3xl overflow-hidden bg-gradient-to-br from-sarang/40 via-red-soft to-red-deep border border-cream/15">
            {/* placeholder hero photo plate — replace with real product shot */}
            <div class="absolute inset-0 grid place-items-center">
              <Arfan pose="steamer" class="w-64 md:w-80 h-auto"/>
            </div>
            <div class="absolute top-4 left-4 inline-flex items-center gap-2 rounded-full bg-cream text-red-deep px-3 py-1 text-[0.6875rem] tracking-[0.2em] uppercase font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-red"></span>
              100% Halal
            </div>
            <div class="absolute bottom-4 left-4 right-4 flex items-end justify-between text-cream">
              <div>
                <p class="eyebrow text-cream/60">Andalan</p>
                <p class="font-display-x text-3xl uppercase leading-none mt-1">Hakau Udang</p>
              </div>
              <p class="font-display-x text-2xl tabular leading-none">RP18.000</p>
            </div>
            {/* TODO(owner): swap for real photo of a steamer of dimsum */}
          </div>
        </div>
      </div>

      {/* aggregator strip on red */}
      <div class="mt-16 md:mt-20 border-t border-cream/15 pt-7">
        <AggregatorStrip variant="dark" compact={true}/>
      </div>
    </div>
  </section>

  {/* MARQUEE STRIP — bold cream band */}
  <section class="bg-cream border-y border-charcoal/10 py-5 md:py-6 overflow-hidden">
    <div class="font-display-x text-3xl md:text-5xl text-charcoal whitespace-nowrap flex gap-10 items-center uppercase">
      <span>Banyak Varian</span><span class="text-red">·</span>
      <span>Halal</span><span class="text-red">·</span>
      <span>Harga Dompetan</span><span class="text-red">·</span>
      <span>Ramah Keluarga</span><span class="text-red">·</span>
      <span>Banyak Varian</span><span class="text-red">·</span>
      <span>Halal</span><span class="text-red">·</span>
      <span>Harga Dompetan</span><span class="text-red">·</span>
    </div>
  </section>

  {/* MENU SECTION — center label + grid */}
  <section class="bg-cream">
    <div class="mx-auto max-w-7xl px-5 md:px-8 py-20 md:py-28">
      <div class="text-center max-w-3xl mx-auto">
        <p class="eyebrow text-red">Yang Paling Dicari</p>
        <h2 class="font-display-x text-5xl md:text-7xl mt-4 text-charcoal uppercase leading-[0.92]">
          Di Setiap Gigitan,<br/>Rasa Rumah.
        </h2>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {heroItems.map((m) => <MenuCard {...m} />)}
      </div>

      <div class="mt-10 flex justify-between items-end text-charcoal/60 text-sm border-t border-charcoal/15 pt-5">
        <span class="font-display-x text-2xl uppercase tracking-tight text-charcoal">Look Menu</span>
        <a href="/menu" class="inline-flex items-center gap-2 hover:text-charcoal transition-colors">
          Lihat semua
          <Icon name="arrow-right" size={14}/>
        </a>
        <span class="font-display-x text-2xl uppercase tracking-tight text-charcoal tabular">{menu.length}</span>
      </div>
    </div>
  </section>

  {/* SPLIT FEATURE CARDS — Sewa Steling + Lokasi */}
  <section class="bg-cream">
    <div class="mx-auto max-w-7xl px-5 md:px-8 pb-20 md:pb-28 grid gap-5 md:grid-cols-2">
      {/* SEWA STELING */}
      <a href="/sewa-steling" class="group relative aspect-[5/4] md:aspect-[4/3] rounded-3xl overflow-hidden bg-gradient-to-br from-red to-red-deep text-cream p-7 md:p-9 flex flex-col justify-between hover:-translate-y-0.5 transition-transform">
        <div>
          <p class="eyebrow text-cream/60">Untuk Pemilik Usaha</p>
          <h3 class="font-display-x text-4xl md:text-5xl uppercase mt-3 leading-[0.95]">
            Sewa Steling<br/>
            <span class="text-sarang">Jualan Dimsumnya.</span>
          </h3>
        </div>
        <div class="flex items-end justify-between">
          <p class="text-cream/75 max-w-xs leading-relaxed">
            Steling, supply rutin, pelatihan singkat. Mulai dari per bulan.
          </p>
          <span class="inline-flex items-center gap-2 rounded-full bg-cream text-red-deep px-5 py-2.5 text-sm font-medium group-hover:bg-sarang transition-colors">
            Lihat Skema
            <Icon name="arrow-right" size={14}/>
          </span>
        </div>
        <Arfan pose="steamer" class="absolute -right-6 -bottom-6 w-44 h-auto opacity-95 hidden md:block"/>
      </a>

      {/* LOKASI */}
      <a href="/lokasi" class="group relative aspect-[5/4] md:aspect-[4/3] rounded-3xl overflow-hidden bg-charcoal text-cream p-7 md:p-9 flex flex-col justify-between hover:-translate-y-0.5 transition-transform">
        <div>
          <p class="eyebrow text-sarang">Mampir Langsung</p>
          <h3 class="font-display-x text-4xl md:text-5xl uppercase mt-3 leading-[0.95]">
            Jalan Ciptaland,<br/>
            <span class="text-sarang">Tiban — Batam.</span>
          </h3>
        </div>
        <div class="flex items-end justify-between gap-4">
          <div class="text-cream/75 leading-relaxed">
            <p class="inline-flex items-center gap-2">
              <Icon name="clock" size={14} class="text-sarang"/>
              Buka tiap hari · <span class="tabular">10:00 — 00:00</span>
            </p>
          </div>
          <span class="inline-flex items-center gap-2 rounded-full bg-sarang text-charcoal px-5 py-2.5 text-sm font-medium group-hover:bg-cream transition-colors">
            Buka Maps
            <Icon name="arrow-up-right" size={14}/>
          </span>
        </div>
      </a>
    </div>
  </section>

  {/* SARANGERS — IG UGC strip on red */}
  <section class="bg-red text-cream">
    <div class="mx-auto max-w-7xl px-5 md:px-8 py-20 md:py-28">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
        <div>
          <p class="eyebrow text-sarang">Komunitas</p>
          <h2 class="font-display-x text-5xl md:text-7xl uppercase mt-3 leading-[0.92]">
            #<span class="text-sarang">Sarangers</span>
          </h2>
          <p class="mt-4 text-cream/75 max-w-md">
            Tag <a href={links.ig} target="_blank" rel="noopener" class="underline underline-offset-4 decoration-sarang decoration-2 text-cream">@dimsum_sarang</a> di IG biar masuk dinding ini.
          </p>
        </div>
        <a href={links.ig} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-cream/40 px-5 py-2.5 text-sm hover:bg-cream/10 transition-colors">
          <Icon name="instagram" size={14}/>
          Follow @dimsum_sarang
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {Array.from({ length: 6 }).map((_, i) => (
          <a href={links.ig} target="_blank" rel="noopener" class="group relative aspect-square rounded-2xl bg-gradient-to-br from-sarang/25 to-red-deep border border-cream/15 overflow-hidden hover:border-cream/40 transition-colors" aria-label={`Foto Sarangers #${i + 1}`}>
            <div class="absolute inset-0 grid place-items-center font-display-x text-7xl text-cream/15 uppercase">S</div>
            <div class="absolute bottom-2.5 left-2.5 right-2.5 flex items-center justify-between text-[0.6875rem] text-cream/70 tracking-[0.18em] uppercase">
              <span>@sarangers</span>
              <Icon name="arrow-up-right" size={12}/>
            </div>
          </a>
        ))}
      </div>
      {/* TODO(owner): wire real IG embed/feed */}
    </div>
  </section>

  {/* YELLOW CTA BAND */}
  <section class="bg-sarang text-charcoal">
    <div class="mx-auto max-w-7xl px-5 md:px-8 py-12 md:py-16 flex flex-wrap items-center justify-between gap-6">
      <h2 class="font-display-x text-3xl md:text-5xl uppercase leading-[0.95]">
        Pesan Online,<br class="md:hidden"/> Atau Mampir Hari Ini.
      </h2>
      <div class="flex flex-wrap gap-3">
        <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-7 py-3.5 font-medium hover:bg-red-deep transition-colors">
          <Icon name="message-circle" size={16}/>
          Pesan Sekarang
        </a>
        <a href="/lokasi" class="inline-flex items-center gap-2 rounded-full border-2 border-charcoal px-7 py-3.5 font-medium hover:bg-charcoal hover:text-cream transition-colors">
          Lihat Lokasi
          <Icon name="arrow-right" size={16}/>
        </a>
      </div>
    </div>
  </section>
</Base>
