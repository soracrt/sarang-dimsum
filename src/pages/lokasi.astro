---
import Base from '../layouts/Base.astro';
import TopNav from '../components/TopNav.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const hours = [
  { d: 'Senin – Jumat', h: '10:00 — 00:00' },
  { d: 'Sabtu',          h: '10:00 — 00:00' },
  { d: 'Minggu',         h: '10:00 — 00:00' },
];

const orderOpts = [
  { icon: 'message-circle' as const, label: 'WhatsApp',  d: 'Paling cepat, langsung ke dapur.', href: links.waOrder },
  { icon: 'bike'           as const, label: 'GoFood',    d: 'Diantar via Gojek.',               href: links.gofood },
  { icon: 'bike'           as const, label: 'GrabFood',  d: 'Diantar via Grab.',                href: links.grabfood },
  { icon: 'bike'           as const, label: 'ShopeeFood',d: 'Diantar via Shopee.',              href: links.shopeefood },
  { icon: 'home'           as const, label: 'Mampir',    d: 'Datang langsung — selalu welcome.',href: links.maps },
];
---

<Base hideHeader title="Lokasi & Jam — Sarang Dimsum" description="Alamat, jam buka, dan cara ke Sarang Dimsum di Jalan Ciptaland, Tiban, Batam.">
  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* RED HERO */}
  <section class="relative bg-red text-cream overflow-hidden">
    <TopNav variant="red"/>

    <div class="absolute top-32 right-6 md:right-12 z-10 pointer-events-none">
      <div class="stamp stamp-tilt-r text-sarang text-base md:text-xl">Tiban · BTM</div>
    </div>

    <div class="shell px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-20">
      <div class="flex items-center gap-3 mb-6">
        <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Lokasi & Jam Buka</span>
      </div>

      <h1 class="font-display-x uppercase text-cream leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(3.5rem, 8vw, 8rem);">
        Mampir Ke<br/>
        <span class="text-sarang">Tiban.</span>
      </h1>

      <p class="mt-8 max-w-xl text-lg text-cream/85 leading-[1.7]">
        Buka tiap hari, jam 10 pagi sampai tengah malam. Ada tempat duduk buat makan langsung, atau tinggal ambil bawa pulang.
      </p>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* MAP + DETAILS — asymmetric, no rounded cards */}
  <section class="bg-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24 grid md:grid-cols-12 gap-10 md:gap-12">

      {/* MAP — 7 cols */}
      <div class="md:col-span-7 relative bg-cream-soft border-2 border-charcoal min-h-[400px] md:min-h-[520px]">
        {/* corner stamps */}
        <span class="absolute top-3 left-4 text-[0.6875rem] uppercase tracking-[0.28em] text-charcoal-mute font-semibold">Lokasi</span>
        <span class="absolute top-3 right-4 text-[0.6875rem] uppercase tracking-[0.28em] text-charcoal-mute font-semibold tabular">N° 27</span>

        {/* TODO(owner): embed real Google Maps iframe */}
        <div class="absolute inset-0 grid place-items-center px-6">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto bg-red text-cream grid place-items-center">
              <Icon name="map-pin" size={28}/>
            </div>
            <p class="mt-5 font-display-x text-3xl uppercase">Sarang Dimsum</p>
            <p class="mt-1 text-charcoal-mute uppercase tracking-[0.2em] text-sm">Jalan Ciptaland · Tiban</p>
            <a href={links.maps} target="_blank" rel="noopener" class="mt-6 inline-flex items-center gap-2 bg-charcoal text-cream px-5 py-2.5 text-sm uppercase tracking-[0.18em] font-bold hover:bg-red transition-colors">
              <Icon name="map-pin" size={14}/>
              Buka di Google Maps
            </a>
          </div>
        </div>
      </div>

      {/* DETAILS — 5 cols, ticket-stub style */}
      <aside class="md:col-span-5 space-y-6">
        {/* HOURS TICKET */}
        <div class="bg-cream-soft border-2 border-charcoal relative">
          <div class="absolute -top-2 left-1/2 -translate-x-1/2 flex gap-1.5">
            <span class="w-1 h-4 bg-cream"></span><span class="w-1 h-4 bg-cream"></span><span class="w-1 h-4 bg-cream"></span>
          </div>
          <div class="px-6 pt-7 pb-5">
            <div class="flex items-center justify-between text-[0.6875rem] uppercase tracking-[0.28em] text-charcoal-mute font-semibold">
              <span>Jam Buka</span>
              <span>Tiap Hari</span>
            </div>
            <p class="font-display-x text-5xl md:text-6xl tabular text-red mt-3 leading-none">10:00 — 00:00</p>
          </div>
          <div class="border-t-2 border-dotted border-charcoal/40 mx-6"></div>
          <ul class="px-6 py-5 space-y-2 text-sm">
            {hours.map((r) => (
              <div class="receipt-row text-charcoal"><span>{r.d}</span><span class="leader"></span><span class="tabular font-medium">{r.h}</span></div>
            ))}
          </ul>
        </div>

        {/* ADDRESS BLOCK */}
        <div class="bg-charcoal text-cream p-6 md:p-7 relative">
          <span class="absolute top-3 right-4 text-[0.6875rem] uppercase tracking-[0.28em] text-cream/70 font-semibold">Alamat</span>
          <h3 class="font-display-x text-2xl md:text-3xl uppercase mt-6 leading-tight">
            Jalan Ciptaland<br/>
            Tiban, Batam<br/>
            <span class="text-sarang">Kepulauan Riau</span>
          </h3>
          <p class="hand text-sarang text-xl mt-4">— landmark: deket warung kopi tiban indah</p>
        </div>
      </aside>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* CARA PESAN — receipt-style list */}
  <section class="bg-red text-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24">
      <div class="grid md:grid-cols-12 gap-10 md:gap-12 items-start">
        <div class="md:col-span-5">
          <div class="flex items-center gap-3 mb-6">
            <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
            <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Cara Pesan</span>
          </div>
          <h2 class="font-display-x uppercase text-cream leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(2.25rem, 5vw, 5rem);">
            Lima Cara,<br/>
            <span class="text-sarang">Pilih Yang Pas.</span>
          </h2>
        </div>

        <ul class="md:col-span-7 divide-y divide-cream/20 border-y-2 border-cream/30">
          {orderOpts.map((o, i) => (
            <li>
              <a href={o.href} target="_blank" rel="noopener" class="group flex items-center gap-5 py-5 hover:bg-red-deep px-2 -mx-2 transition-colors">
                <span class="font-display-x text-sarang text-xl tabular w-12 leading-none shrink-0">{String(i+1).padStart(2,'0')}</span>
                <span class="flex-1 min-w-0">
                  <span class="block font-display-x text-2xl md:text-3xl uppercase text-cream leading-none">{o.label}</span>
                  <span class="block text-cream/75 text-sm mt-1.5">{o.d}</span>
                </span>
                <Icon name="arrow-up-right" size={20} class="text-sarang opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all"/>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>
