---
import Base from '../layouts/Base.astro';
import { links } from '../lib/links';

const hours = [
  { d: 'Senin – Jumat', h: '10:00 — 00:00' },
  { d: 'Sabtu', h: '10:00 — 00:00' },
  { d: 'Minggu', h: '10:00 — 00:00' },
];
---

<Base title="Lokasi & Jam — Sarang Dimsum" description="Alamat, jam buka, dan cara ke Sarang Dimsum di Jalan Ciptaland, Tiban, Batam.">
  <section class="mx-auto max-w-6xl px-5 md:px-8 py-12 md:py-16">
    <span class="text-xs uppercase tracking-[0.2em] text-charcoal-mute">Lokasi & Jam</span>
    <h1 class="font-display text-4xl md:text-5xl mt-2">Mampir ke Tiban.</h1>
    <p class="mt-4 text-lg text-charcoal-soft max-w-2xl">
      Buka tiap hari, jam 10 pagi sampai tengah malam. Ada tempat duduk buat makan langsung, atau tinggal ambil bawa pulang.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 md:px-8 pb-20 grid md:grid-cols-2 gap-8">
    <div class="rounded-3xl border border-charcoal/10 bg-cream-soft p-6 md:p-8">
      <h2 class="font-display text-2xl">Alamat</h2>
      <p class="mt-3 text-charcoal-soft text-lg">
        Jalan Ciptaland, Tiban<br/>
        Batam, Kepulauan Riau, Indonesia
      </p>
      <a href={links.maps} target="_blank" rel="noopener" class="mt-5 inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-5 py-3 font-medium hover:bg-charcoal-soft transition-colors">
        Buka di Google Maps
      </a>

      <h2 class="font-display text-2xl mt-10">Jam buka</h2>
      <ul class="mt-3 divide-y divide-charcoal/10">
        {hours.map((r) => (
          <li class="flex justify-between py-2 text-charcoal-soft">
            <span>{r.d}</span><span class="font-medium text-charcoal">{r.h}</span>
          </li>
        ))}
      </ul>

      <h2 class="font-display text-2xl mt-10">Cara pesan</h2>
      <ul class="mt-3 space-y-2 text-charcoal-soft">
        <li>📞 <a href={links.waOrder} class="text-sarang-deep hover:underline">WhatsApp</a> — paling cepat, langsung ke dapur.</li>
        <li>🛵 <a href={links.gofood} class="text-sarang-deep hover:underline">GoFood</a> · <a href={links.grabfood} class="text-sarang-deep hover:underline">GrabFood</a> · <a href={links.shopeefood} class="text-sarang-deep hover:underline">ShopeeFood</a></li>
        <li>🏠 Mampir langsung — selalu welcome.</li>
      </ul>
    </div>

    <div class="rounded-3xl bg-cream-deep border border-charcoal/10 min-h-[420px] flex items-center justify-center">
      {/* TODO(owner): embed real Google Maps iframe with pin coordinates */}
      <div class="text-center px-6">
        <div class="text-6xl">📍</div>
        <p class="mt-4 font-display text-2xl text-charcoal">Sarang Dimsum</p>
        <p class="text-charcoal-mute">Jalan Ciptaland, Tiban — Batam</p>
      </div>
    </div>
  </section>
</Base>
