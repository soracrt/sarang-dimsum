---
import Base from '../layouts/Base.astro';
import TopNav from '../components/TopNav.astro';
import MenuCard from '../components/MenuCard.astro';
import AggregatorStrip from '../components/AggregatorStrip.astro';
import Icon from '../components/Icon.astro';
import { menu, categoryLabel, type MenuItem } from '../data/menu';
import { links } from '../lib/links';

const grouped = menu.reduce<Record<MenuItem['category'], MenuItem[]>>((acc, m) => {
  (acc[m.category] ||= []).push(m);
  return acc;
}, {} as any);

const order: MenuItem['category'][] = ['paket', 'kukus', 'goreng', 'mie', 'minuman'];
---

<Base hideHeader title="Menu — Sarang Dimsum" description="Daftar lengkap menu dimsum halal di Sarang Dimsum Tiban Batam. Kukus, goreng, mie, paket hemat — harga dompetan.">
  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* RED HERO */}
  <section class="relative bg-red text-cream overflow-hidden">
    <TopNav variant="red"/>

    <div class="absolute top-32 right-6 md:right-12 z-10 pointer-events-none">
      <div class="stamp stamp-tilt-l text-sarang text-base md:text-xl">{menu.length} Menu · Halal</div>
    </div>

    <div class="px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-20">
      <div class="flex items-center gap-3 mb-6">
        <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Daftar Menu Lengkap</span>
      </div>

      <h1 class="font-display-x uppercase text-cream leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(4.5rem, 14vw, 14rem);">
        Pilih Dimsum<br/>
        <span class="text-sarang">Kesukaanmu.</span>
      </h1>

      <p class="mt-8 max-w-xl text-lg text-cream/85 leading-[1.7]">
        Kukus, goreng, mie, paket hemat. Semua harga sudah termasuk. Stok bisa beda tiap hari — kalau habis, kami ganti.
      </p>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* STICKY CATEGORY NAV — sharp-edged, no rounded pills */}
  <nav class="sticky top-0 z-30 bg-cream border-b-2 border-charcoal">
    <div class="px-5 md:px-10 py-3 flex gap-0 overflow-x-auto text-sm font-semibold">
      {order.map((c, i) => (
        <a href={`#${c}`} class={`px-5 py-2 uppercase tracking-[0.18em] text-charcoal hover:bg-red hover:text-cream whitespace-nowrap transition-colors ${i > 0 ? 'border-l border-charcoal/15' : ''}`}>
          {categoryLabel[c]}
          <span class="text-charcoal-mute font-normal text-xs ml-2 tabular">{String(grouped[c]?.length || 0).padStart(2,'0')}</span>
        </a>
      ))}
    </div>
  </nav>

  {/* MENU SECTIONS */}
  <section class="bg-cream">
    <div class="px-5 md:px-10 py-12 md:py-16 space-y-20">
      {order.map((c, ci) => (
        <div id={c}>
          {/* category header — large + numbered */}
          <div class="flex items-end justify-between gap-4 mb-8 border-b-2 border-charcoal pb-4">
            <div class="flex items-baseline gap-5">
              <span class="font-display-x text-2xl md:text-3xl tabular text-red leading-none">{String(ci+1).padStart(2,'0')}</span>
              <h2 class="font-display-x text-4xl md:text-6xl uppercase leading-none">{categoryLabel[c]}</h2>
            </div>
            <span class="hand text-red text-2xl md:text-3xl">{grouped[c]?.length || 0} pilihan</span>
          </div>

          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {grouped[c]?.map((m) => <MenuCard {...m} category={c} />)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* CTA — order options */}
  <section class="bg-charcoal text-cream">
    <div class="px-5 md:px-10 py-20 md:py-24 grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-7">
        <div class="flex items-center gap-3 mb-6">
          <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
          <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Siap Pesan?</span>
        </div>
        <h2 class="font-display-x uppercase leading-[0.88] tracking-[-0.02em]" style="font-size: clamp(3rem, 8vw, 6.5rem);">
          Pilih Cara Yang<br/>
          <span class="text-sarang">Paling Pas.</span>
        </h2>
        <p class="mt-6 text-cream/85 max-w-md leading-[1.7]">Mau makan di tempat, take-away, atau lewat ojol — tinggal pilih.</p>
      </div>
      <div class="md:col-span-5">
        <a href={links.waOrder} target="_blank" rel="noopener" class="block w-full bg-sarang text-red-deep text-center px-6 py-4 text-sm uppercase tracking-[0.2em] font-bold hover:bg-cream transition-colors">
          <Icon name="message-circle" size={14} class="inline mr-2"/>
          Pesan via WhatsApp
        </a>
        <div class="mt-6 pt-6 border-t border-cream/15">
          <p class="text-[0.6875rem] uppercase tracking-[0.28em] text-cream/70 font-semibold mb-3">Atau Lewat Ojol</p>
          <AggregatorStrip variant="dark"/>
        </div>
        <p class="hand text-sarang text-xl mt-5 text-center">— stok harian, kalau habis kami ganti besok</p>
      </div>
    </div>
  </section>
</Base>
