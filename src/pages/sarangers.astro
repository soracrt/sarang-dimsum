---
import Base from '../layouts/Base.astro';
import { links } from '../lib/links';

const tiles = ['🥟','🦐','🍜','🥯','🍗','🌯','🍱','👨‍👩‍👧','🍵','🍫','🥢','☕'];
---

<Base title="Sarangers — Komunitas Sarang Dimsum" description="Galeri foto pelanggan Sarang Dimsum di IG. Tag @dimsum_sarang biar masuk dinding ini.">
  <section class="mx-auto max-w-6xl px-5 md:px-8 py-12 md:py-16 text-center">
    <span class="text-xs uppercase tracking-[0.2em] text-charcoal-mute">Komunitas</span>
    <h1 class="font-display text-4xl md:text-5xl mt-2">Halo, <span class="italic text-sarang-deep">Sarangers</span>.</h1>
    <p class="mt-4 text-lg text-charcoal-soft max-w-2xl mx-auto">
      Foto-foto kamu makan dimsum sama keluarga, sama temen, atau sendirian sambil nonton drakor — semua masuk sini.
      Tag <a href={links.ig} class="text-sarang-deep underline underline-offset-4">@dimsum_sarang</a> di IG, biar kami repost.
    </p>
    <a href={links.ig} target="_blank" rel="noopener" class="mt-6 inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-6 py-3 font-medium hover:bg-charcoal-soft transition-colors">
      Ikuti di Instagram
    </a>
  </section>

  <section class="mx-auto max-w-6xl px-5 md:px-8 pb-24">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {tiles.map((t, i) => (
        <a href={links.ig} class="aspect-square rounded-2xl bg-cream-soft border border-charcoal/10 hover:border-sarang flex items-center justify-center text-4xl transition-colors" aria-label={`Foto Sarangers #${i + 1}`}>
          {t}
        </a>
      ))}
    </div>
    {/* TODO(owner): replace tile grid with real IG feed (instafeed/embedSocial/Behold) */}
    <p class="mt-8 text-center text-sm text-charcoal-mute">Setiap minggu, kami pilih foto favorit untuk dipajang di sini.</p>
  </section>
</Base>
