---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const benefits = [
  { icon: 'store'           as const, t: 'Steling siap pakai', d: 'Steling bambu kami antar dan rakit di lokasi. Bersih, aman, terstandar.' },
  { icon: 'soup'            as const, t: 'Supply rutin',       d: 'Dimsum diantar segar setiap hari atau minggu. Harga mitra, terkurva sama volume.' },
  { icon: 'heart-handshake' as const, t: 'Pelatihan singkat',  d: 'Tim kamu dilatih cara penyajian, kebersihan, dan layanan dasar. Cukup satu sesi.' },
];

const steps = [
  { n: '01', t: 'Isi form / chat WA', d: 'Ceritakan lokasi & kapasitas tempat kamu.' },
  { n: '02', t: 'Survei ringan',      d: 'Tim Sarang cek kelayakan & estimasi target.' },
  { n: '03', t: 'Pasang & latih',     d: 'Steling dipasang, tim kamu dilatih singkat.' },
  { n: '04', t: 'Mulai jualan',       d: 'Supply rutin, kamu fokus ke pelanggan.' },
];
---

<Base title="Sewa Steling — Sarang Dimsum" description="Skema sewa steling dimsum Sarang. Cocok buat warung kopi, ruko, atau pemilik usaha yang mau nambah lini halal cepat saji.">
  <section class="relative bg-charcoal text-cream overflow-hidden">
    <div class="absolute inset-0 opacity-[0.07] pointer-events-none">
      <div class="absolute -top-32 -left-32 w-[40rem] h-[40rem] rounded-full bg-sarang blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-5 md:px-8 py-20 md:py-28 grid md:grid-cols-[1.4fr_auto] gap-12 items-center">
      <div>
        <p class="eyebrow text-sarang">Untuk pemilik usaha</p>
        <h1 class="font-display-x text-6xl md:text-8xl text-cream leading-[0.9] mt-4">
          Sewa stelingnya,<br/>
          <span class="text-sarang">jualan dimsumnya.</span>
        </h1>
        <p class="mt-7 text-lg text-cream/75 max-w-2xl leading-relaxed">
          Skema mitra Sarang: kamu sediakan tempat — warung, ruko, food court, kios — kami sediakan steling, supply dimsum, dan pelatihan.
          Cocok buat usaha yang ingin nambah lini halal cepat saji tanpa pusing soal resep dan supplier.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a href={links.waReseller} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-sarang text-charcoal px-7 py-3.5 font-medium hover:bg-sarang-deep transition-colors">
            <Icon name="message-circle" size={16}/>
            Tanya skema via WhatsApp
          </a>
          <a href="#form" class="inline-flex items-center gap-2 rounded-full border border-cream/25 px-7 py-3.5 font-medium hover:bg-cream/5 transition-colors">
            Isi form dulu
            <Icon name="arrow-right" size={14}/>
          </a>
        </div>
      </div>
      <Arfan pose="steamer" class="hidden md:block w-72 h-auto" />
    </div>
  </section>

  {/* benefits */}
  <section class="mx-auto max-w-6xl px-5 md:px-8 py-24">
    <p class="eyebrow">Apa yang kamu dapat</p>
    <h2 class="font-display text-3xl md:text-4xl mt-3 max-w-2xl">Tiga hal yang Sarang siapkan, biar kamu fokus jualan.</h2>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {benefits.map((b) => (
        <div class="rounded-3xl border border-charcoal/10 bg-cream-soft p-7">
          <div class="w-11 h-11 rounded-full bg-cream border border-charcoal/15 grid place-items-center text-charcoal">
            <Icon name={b.icon} size={20}/>
          </div>
          <h3 class="font-display text-xl mt-5">{b.t}</h3>
          <p class="mt-2 text-charcoal-mute leading-relaxed">{b.d}</p>
        </div>
      ))}
    </div>
  </section>

  {/* how it works */}
  <section class="bg-cream-soft border-y border-charcoal/8">
    <div class="mx-auto max-w-6xl px-5 md:px-8 py-24">
      <div class="flex items-end justify-between gap-6 mb-12 flex-wrap">
        <div>
          <p class="eyebrow">Caranya</p>
          <h2 class="font-display text-4xl md:text-5xl mt-3 leading-tight">Empat langkah, <em>selesai.</em></h2>
        </div>
      </div>
      <ol class="grid gap-5 md:grid-cols-4">
        {steps.map((s) => (
          <li class="rounded-3xl bg-cream border border-charcoal/10 p-6">
            <span class="font-display text-3xl tabular text-charcoal-mute">{s.n}</span>
            <h3 class="font-display text-xl mt-5">{s.t}</h3>
            <p class="mt-2 text-charcoal-mute leading-relaxed">{s.d}</p>
          </li>
        ))}
      </ol>
      <p class="mt-8 text-sm text-charcoal-mute max-w-2xl">
        {/* TODO(owner): confirm exact rental terms, deposit, supply pricing tiers */}
        *Skema biaya & deposit menyesuaikan ukuran tempat dan target volume. Detail lengkap dibahas saat survei.
      </p>
    </div>
  </section>

  {/* form */}
  <section id="form" class="mx-auto max-w-3xl px-5 md:px-8 py-24">
    <p class="eyebrow">Mulai obrolan</p>
    <h2 class="font-display text-4xl md:text-5xl mt-3 leading-[1.02]">Tertarik? <em>Isi data dulu.</em></h2>
    <p class="mt-4 text-charcoal-soft text-lg">Kami balas dalam 1×24 jam, biasanya lebih cepat lewat WhatsApp.</p>

    <form
      class="mt-10 grid gap-4 rounded-3xl border border-charcoal/10 bg-cream p-7 md:p-9"
      onsubmit="event.preventDefault(); const f=event.target; const msg=`Halo Sarang, saya tertarik Sewa Steling.%0A%0ANama: ${f.nama.value}%0ALokasi tempat: ${f.lokasi.value}%0AJenis usaha: ${f.usaha.value}%0ACatatan: ${f.catatan.value}`; window.open('https://wa.me/6281234567890?text=' + msg, '_blank');"
    >
      <label class="grid gap-1.5">
        <span class="eyebrow">Nama</span>
        <input name="nama" required class="rounded-xl border border-charcoal/20 bg-cream-soft px-4 py-3.5 focus:border-charcoal focus:bg-cream focus:outline-none transition-colors" placeholder="Nama kamu" />
      </label>
      <label class="grid gap-1.5">
        <span class="eyebrow">Lokasi tempat usaha</span>
        <input name="lokasi" required class="rounded-xl border border-charcoal/20 bg-cream-soft px-4 py-3.5 focus:border-charcoal focus:bg-cream focus:outline-none transition-colors" placeholder="Misal: Batam Center, Nagoya, Tiban" />
      </label>
      <label class="grid gap-1.5">
        <span class="eyebrow">Jenis usaha</span>
        <input name="usaha" class="rounded-xl border border-charcoal/20 bg-cream-soft px-4 py-3.5 focus:border-charcoal focus:bg-cream focus:outline-none transition-colors" placeholder="Warung kopi, ruko, food court, dll." />
      </label>
      <label class="grid gap-1.5">
        <span class="eyebrow">Catatan (opsional)</span>
        <textarea name="catatan" rows="3" class="rounded-xl border border-charcoal/20 bg-cream-soft px-4 py-3.5 focus:border-charcoal focus:bg-cream focus:outline-none transition-colors resize-none" placeholder="Apa pun yang ingin kamu sampaikan dulu."></textarea>
      </label>
      <button type="submit" class="mt-3 inline-flex items-center justify-center gap-2 rounded-full bg-charcoal text-cream px-6 py-3.5 font-medium hover:bg-charcoal-soft transition-colors">
        <Icon name="message-circle" size={16}/>
        Kirim via WhatsApp
      </button>
      <p class="text-xs text-charcoal-mute text-center">Form ini akan membuka WhatsApp dengan pesan terisi otomatis.</p>
    </form>
  </section>
</Base>
