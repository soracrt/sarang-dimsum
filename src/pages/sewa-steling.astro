---
import Base from '../layouts/Base.astro';
import TopNav from '../components/TopNav.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const benefits = [
  { n: '01', t: 'Steling Siap Pakai',  d: 'Steling bambu kami antar dan rakit di lokasi. Bersih, aman, terstandar.' },
  { n: '02', t: 'Supply Rutin',        d: 'Dimsum diantar segar setiap hari atau minggu. Harga mitra, terkurva sama volume.' },
  { n: '03', t: 'Pelatihan Singkat',   d: 'Tim kamu dilatih cara penyajian, kebersihan, dan layanan dasar. Cukup satu sesi.' },
];

const steps = [
  { n: '01', t: 'Isi form / chat WA', d: 'Ceritakan lokasi & kapasitas tempat kamu.' },
  { n: '02', t: 'Survei ringan',      d: 'Tim Sarang cek kelayakan & estimasi target.' },
  { n: '03', t: 'Pasang & latih',     d: 'Steling dipasang, tim kamu dilatih singkat.' },
  { n: '04', t: 'Mulai jualan',       d: 'Supply rutin, kamu fokus ke pelanggan.' },
];
---

<Base hideHeader title="Sewa Steling — Sarang Dimsum" description="Skema sewa steling dimsum Sarang. Cocok buat warung kopi, ruko, atau pemilik usaha yang mau nambah lini halal cepat saji.">
  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* RED HERO */}
  <section class="relative bg-red text-cream overflow-hidden">
    <TopNav variant="red"/>

    <div class="absolute top-32 right-6 md:right-12 z-10 pointer-events-none">
      <div class="stamp stamp-tilt-l text-sarang text-base md:text-xl">B2B · Mitra Sarang</div>
    </div>

    <div class="shell px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-20">
      <div class="flex items-center gap-3 mb-6">
        <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Untuk Pemilik Usaha</span>
      </div>

      <h1 class="font-display-x uppercase text-cream leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(3.25rem, 7.5vw, 7rem);">
        Sewa Stelingnya,<br/>
        <span class="text-sarang">Jualan Dimsumnya.</span>
      </h1>

      <p class="mt-8 max-w-2xl text-lg text-cream/85 leading-[1.7]">
        Skema mitra Sarang: kamu sediakan tempat — warung, ruko, food court, kios — kami sediakan steling, supply dimsum, dan pelatihan.
        Cocok buat usaha yang mau nambah lini halal cepat saji tanpa pusing soal resep dan supplier.
      </p>

      <div class="mt-9 flex items-center gap-5 flex-wrap">
        <a href={links.waReseller} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-sarang text-red-deep px-6 py-3 text-sm uppercase tracking-[0.2em] font-bold hover:bg-cream transition-colors">
          <Icon name="message-circle" size={14}/>
          Tanya Skema via WA
        </a>
        <a href="#form" class="hand text-sarang text-2xl md:text-3xl hover:text-cream transition-colors inline-flex items-center gap-2">
          atau isi form di bawah
          <svg width="42" height="22" viewBox="0 0 60 30" fill="none" class="-mb-1">
            <path d="M3 18 C 14 6, 30 4, 48 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M40 8 L 48 14 L 42 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* WHAT YOU GET — asymmetric numbered */}
  <section class="bg-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24">
      <div class="flex items-center gap-3 mb-8">
        <span aria-hidden="true" class="block w-12 h-px bg-charcoal"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-charcoal-mute font-semibold">Yang Kamu Dapat</span>
      </div>
      <h2 class="font-display-x uppercase leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(2.5rem, 5.5vw, 5.5rem);">
        Tiga Hal,<br/>
        <span class="text-red">Biar Kamu Fokus Jualan.</span>
      </h2>

      <div class="mt-14 grid gap-10 md:grid-cols-3">
        {benefits.map((b) => (
          <div class="border-t-2 border-charcoal pt-6">
            <span class="font-display-x text-red text-2xl tabular leading-none">{b.n}</span>
            <h3 class="font-display-x uppercase text-3xl mt-4 leading-tight">{b.t}</h3>
            <p class="mt-3 text-charcoal-soft leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* HOW IT WORKS — 4 steps on red */}
  <section class="bg-red text-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24">
      <div class="flex items-center gap-3 mb-8">
        <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Caranya</span>
      </div>
      <h2 class="font-display-x uppercase leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(2.5rem, 5.5vw, 5.5rem);">
        Empat Langkah,<br/>
        <span class="text-sarang">Selesai.</span>
      </h2>

      <ol class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s) => (
          <li class="border-t-2 border-cream/30 pt-6">
            <span class="font-display-x text-sarang text-3xl tabular leading-none">{s.n}</span>
            <h3 class="font-display-x uppercase text-2xl mt-4 leading-tight text-cream">{s.t}</h3>
            <p class="mt-2 text-cream/80 text-sm leading-relaxed">{s.d}</p>
          </li>
        ))}
      </ol>

      <p class="hand text-sarang text-2xl md:text-3xl mt-10 max-w-2xl">— skema biaya & deposit menyesuaikan ukuran tempat dan target volume. detail dibahas saat survei.</p>
      {/* TODO(owner): confirm exact rental terms, deposit, supply pricing tiers */}
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* FORM */}
  <section id="form" class="bg-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24 grid md:grid-cols-12 gap-12 items-start">

      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-6">
          <span aria-hidden="true" class="block w-12 h-px bg-charcoal"></span>
          <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-charcoal-mute font-semibold">Mulai Obrolan</span>
        </div>
        <h2 class="font-display-x uppercase leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(2.25rem, 5vw, 5rem);">
          Tertarik?<br/>
          <span class="text-red">Isi Data Dulu.</span>
        </h2>
        <p class="mt-6 text-charcoal-soft text-lg leading-[1.7] max-w-md">Kami balas dalam 1×24 jam, biasanya lebih cepat lewat WhatsApp.</p>
        <p class="hand text-red text-2xl md:text-3xl mt-6">— form ini langsung buka WA kamu ✻</p>
      </div>

      <form
        class="md:col-span-7 grid gap-5 bg-cream-soft border-2 border-charcoal p-6 md:p-8"
        onsubmit="event.preventDefault(); const f=event.target; const msg=`Halo Sarang, saya tertarik Sewa Steling.%0A%0ANama: ${f.nama.value}%0ALokasi tempat: ${f.lokasi.value}%0AJenis usaha: ${f.usaha.value}%0ACatatan: ${f.catatan.value}`; window.open('https://wa.me/6281234567890?text=' + msg, '_blank');"
      >
        <label class="grid gap-1.5">
          <span class="text-[0.6875rem] uppercase tracking-[0.22em] text-charcoal-mute font-semibold">Nama</span>
          <input name="nama" required class="border-2 border-charcoal/20 bg-cream px-4 py-3.5 focus:border-charcoal focus:outline-none transition-colors text-charcoal" placeholder="Nama kamu" />
        </label>
        <label class="grid gap-1.5">
          <span class="text-[0.6875rem] uppercase tracking-[0.22em] text-charcoal-mute font-semibold">Lokasi tempat usaha</span>
          <input name="lokasi" required class="border-2 border-charcoal/20 bg-cream px-4 py-3.5 focus:border-charcoal focus:outline-none transition-colors text-charcoal" placeholder="Misal: Batam Center, Nagoya, Tiban" />
        </label>
        <label class="grid gap-1.5">
          <span class="text-[0.6875rem] uppercase tracking-[0.22em] text-charcoal-mute font-semibold">Jenis usaha</span>
          <input name="usaha" class="border-2 border-charcoal/20 bg-cream px-4 py-3.5 focus:border-charcoal focus:outline-none transition-colors text-charcoal" placeholder="Warung kopi, ruko, food court, dll." />
        </label>
        <label class="grid gap-1.5">
          <span class="text-[0.6875rem] uppercase tracking-[0.22em] text-charcoal-mute font-semibold">Catatan (opsional)</span>
          <textarea name="catatan" rows="3" class="border-2 border-charcoal/20 bg-cream px-4 py-3.5 focus:border-charcoal focus:outline-none transition-colors resize-none text-charcoal" placeholder="Apa pun yang ingin kamu sampaikan dulu."></textarea>
        </label>
        <button type="submit" class="mt-2 inline-flex items-center justify-center gap-2 bg-red text-cream px-6 py-4 text-sm uppercase tracking-[0.2em] font-bold hover:bg-red-deep transition-colors">
          <Icon name="message-circle" size={14}/>
          Kirim via WhatsApp
        </button>
        <p class="text-xs text-charcoal-mute text-center">Form ini akan membuka WhatsApp dengan pesan terisi otomatis.</p>
      </form>
    </div>
  </section>
</Base>
