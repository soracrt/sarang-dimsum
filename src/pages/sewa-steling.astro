---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import { links } from '../lib/links';
---

<Base title="Sewa Steling — Sarang Dimsum" description="Skema sewa steling dimsum Sarang. Cocok buat warung kopi, ruko, atau pemilik usaha yang mau nambah lini halal cepat saji.">
  <section class="bg-charcoal text-cream">
    <div class="mx-auto max-w-6xl px-5 md:px-8 py-16 md:py-24 grid md:grid-cols-[1.3fr_auto] gap-10 items-center">
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.2em] text-sarang mb-4">Untuk pemilik usaha</span>
        <h1 class="font-display text-4xl md:text-5xl text-cream leading-[1.05]">
          Sewa stelingnya, <span class="italic text-sarang">jualan dimsumnya.</span>
        </h1>
        <p class="mt-5 text-lg text-cream/80 max-w-2xl">
          Skema mitra Sarang: kamu sediakan tempat (warung, ruko, food court, kios), kami sediakan steling, supply dimsum, dan pelatihan.
          Cocok buat usaha yang ingin nambah lini halal cepat saji — tanpa pusing soal resep dan supplier.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href={links.waReseller} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-sarang text-charcoal px-6 py-3 font-medium hover:bg-sarang-deep transition-colors">
            Tanya skema via WhatsApp
          </a>
          <a href="#form" class="inline-flex items-center gap-2 rounded-full border border-cream/30 px-6 py-3 font-medium hover:bg-cream/10 transition-colors">
            Isi form dulu
          </a>
        </div>
      </div>
      <Arfan pose="steamer" class="hidden md:block w-72 h-auto" />
    </div>
  </section>

  {/* benefits */}
  <section class="mx-auto max-w-6xl px-5 md:px-8 py-20">
    <div class="grid gap-8 md:grid-cols-3">
      {[
        { t: 'Steling siap pakai', d: 'Steling bambu kami antar dan rakit di lokasi. Bersih, aman, terstandar.' },
        { t: 'Supply rutin', d: 'Dimsum diantar segar setiap hari/minggu. Harga mitra, terkurva sama volume.' },
        { t: 'Pelatihan singkat', d: 'Tim kamu dilatih cara penyajian, kebersihan, dan layanan dasar. 1 sesi cukup.' },
      ].map((b) => (
        <div class="rounded-3xl border border-charcoal/10 bg-cream-soft p-6">
          <h3 class="font-display text-xl">{b.t}</h3>
          <p class="mt-2 text-charcoal-mute">{b.d}</p>
        </div>
      ))}
    </div>
  </section>

  {/* how it works */}
  <section class="bg-cream-soft border-y border-charcoal/10">
    <div class="mx-auto max-w-6xl px-5 md:px-8 py-20">
      <h2 class="font-display text-3xl md:text-4xl">Caranya gampang.</h2>
      <ol class="mt-8 grid gap-6 md:grid-cols-4">
        {[
          { n: '1', t: 'Isi form / chat WA', d: 'Ceritakan lokasi & kapasitas tempat kamu.' },
          { n: '2', t: 'Survei ringan', d: 'Tim Sarang cek kelayakan & estimasi target.' },
          { n: '3', t: 'Pasang & latih', d: 'Steling dipasang, tim kamu dilatih singkat.' },
          { n: '4', t: 'Mulai jualan', d: 'Supply rutin, kamu fokus ke pelanggan.' },
        ].map((s) => (
          <li class="rounded-3xl bg-cream border border-charcoal/10 p-6">
            <span class="inline-block w-9 h-9 rounded-full bg-sarang text-charcoal font-display text-lg flex items-center justify-center">{s.n}</span>
            <h3 class="font-display text-xl mt-3">{s.t}</h3>
            <p class="mt-2 text-charcoal-mute">{s.d}</p>
          </li>
        ))}
      </ol>
      <p class="mt-6 text-sm text-charcoal-mute">
        {/* TODO(owner): confirm exact rental terms, deposit, supply pricing tiers */}
        *Skema biaya & deposit menyesuaikan ukuran tempat dan target volume. Detail lengkap dibahas saat survei.
      </p>
    </div>
  </section>

  {/* form */}
  <section id="form" class="mx-auto max-w-3xl px-5 md:px-8 py-20">
    <h2 class="font-display text-3xl md:text-4xl">Tertarik? Isi data dulu.</h2>
    <p class="mt-3 text-charcoal-soft">Kami balas dalam 1×24 jam, biasanya lebih cepat lewat WhatsApp.</p>

    <form
      class="mt-8 grid gap-4 rounded-3xl border border-charcoal/10 bg-cream-soft p-6"
      action={links.waReseller}
      method="get"
      onsubmit="event.preventDefault(); const f=event.target; const msg=`Halo Sarang, saya tertarik Sewa Steling.%0A%0ANama: ${f.nama.value}%0ALokasi tempat: ${f.lokasi.value}%0AJenis usaha: ${f.usaha.value}%0ACatatan: ${f.catatan.value}`; window.open('https://wa.me/6281234567890?text=' + msg, '_blank');"
    >
      <label class="grid gap-1">
        <span class="text-sm font-medium">Nama</span>
        <input name="nama" required class="rounded-xl border border-charcoal/20 bg-cream px-4 py-3 focus:border-sarang focus:outline-none" placeholder="Nama kamu" />
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium">Lokasi tempat usaha</span>
        <input name="lokasi" required class="rounded-xl border border-charcoal/20 bg-cream px-4 py-3 focus:border-sarang focus:outline-none" placeholder="Kota / area, misal: Batam Center" />
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium">Jenis usaha</span>
        <input name="usaha" class="rounded-xl border border-charcoal/20 bg-cream px-4 py-3 focus:border-sarang focus:outline-none" placeholder="Warung kopi, ruko, food court, dll." />
      </label>
      <label class="grid gap-1">
        <span class="text-sm font-medium">Catatan (opsional)</span>
        <textarea name="catatan" rows="3" class="rounded-xl border border-charcoal/20 bg-cream px-4 py-3 focus:border-sarang focus:outline-none" placeholder="Apa pun yang ingin kamu sampaikan dulu."></textarea>
      </label>
      <button type="submit" class="mt-2 rounded-full bg-charcoal text-cream px-6 py-3 font-medium hover:bg-charcoal-soft transition-colors">
        Kirim via WhatsApp
      </button>
      <p class="text-xs text-charcoal-mute">Form ini akan membuka WhatsApp dengan pesan terisi otomatis.</p>
    </form>
  </section>
</Base>
