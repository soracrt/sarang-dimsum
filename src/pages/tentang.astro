---
import Base from '../layouts/Base.astro';
import TopNav from '../components/TopNav.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const values = [
  { n: '01', t: 'Halal, Selalu',     d: 'Bahan, proses, dapur. Nggak ada kompromi soal ini.' },
  { n: '02', t: 'Harga Dompetan',    d: 'Mulai dari Rp 14rb. Gak bikin mikir dua kali.' },
  { n: '03', t: 'Ramah Keluarga',    d: 'Porsi pas berdua, paket buat seisi rumah, layanan sopan.' },
];
---

<Base hideHeader title="Tentang — Sarang Dimsum" description="Cerita di balik Sarang Dimsum — dapur kecil halal di Tiban, Batam, didirikan oleh Arfan Putra.">
  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* RED HERO */}
  <section class="relative bg-red text-cream overflow-hidden">
    <TopNav variant="red"/>

    <div class="absolute top-32 right-6 md:right-12 z-10 pointer-events-none">
      <div class="stamp stamp-tilt-r text-sarang text-base md:text-xl">Mulai 2024</div>
    </div>

    <div class="shell px-5 md:px-10 pt-12 md:pt-20 pb-16 md:pb-20">
      <div class="flex items-center gap-3 mb-6">
        <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Tentang Sarang</span>
      </div>

      <h1 class="font-display-x uppercase text-cream leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(3.25rem, 7.5vw, 7rem);">
        Dapur Kecil<br/>
        Di Tiban,<br/>
        <span class="text-sarang">Halal Sepenuhnya.</span>
      </h1>

      <p class="mt-8 max-w-2xl text-lg text-cream/85 leading-[1.7]">
        Dimsum hangat, banyak varian, harga dompetan — dari satu dapur, satu kompor, satu keyakinan: enak nggak harus mahal.
      </p>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* CERITA — asymmetric editorial */}
  <section class="bg-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24 grid md:grid-cols-12 gap-10 md:gap-14 items-start">
      <div class="md:col-span-4">
        <div class="flex items-center gap-3 mb-6">
          <span aria-hidden="true" class="block w-12 h-px bg-charcoal"></span>
          <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-charcoal-mute font-semibold">Cerita Singkat</span>
        </div>
        <p class="font-display-x uppercase text-3xl md:text-5xl leading-[0.95]">Dari Dapur Rumah, <span class="text-red">Pelan-Pelan.</span></p>
      </div>

      <div class="md:col-span-7 md:col-start-6 text-lg md:text-xl text-charcoal-soft space-y-6 leading-[1.75]">
        <p>
          Sarang Dimsum dimulai 2024 di Jalan Ciptaland, Tiban. Resep dicoba puluhan kali sampai keluarga sendiri ngangguk-ngangguk.
        </p>
        <p>
          Dimsum bukan cuma makanan — itu cara kumpul, cara cerita. Itu kenapa kami pilih nama <strong class="text-charcoal font-semibold">Sarang</strong>: biar tempat ini terasa kayak rumah, bukan kayak restoran.
        </p>
        <p>
          Dan koki kecil yang nongkrong di logo kami — namanya <strong class="text-charcoal font-semibold">Arfan</strong>, dipinjem dari nama pemiliknya: <strong class="text-charcoal font-semibold">Arfan Putra</strong>.
        </p>
        <p class="hand text-red text-3xl md:text-4xl mt-8">— mampir, yuk!</p>
      </div>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* TIGA HAL — bold uppercase numbered */}
  <section class="bg-charcoal text-cream">
    <div class="shell px-5 md:px-10 py-20 md:py-24">
      <div class="flex items-center gap-3 mb-6">
        <span aria-hidden="true" class="block w-12 h-px bg-cream/60"></span>
        <span class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/85 font-semibold">Yang Kami Pegang</span>
      </div>
      <h2 class="font-display-x uppercase leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(2.5rem, 5.5vw, 5.5rem);">
        Tiga Hal,<br/>
        <span class="text-sarang">Tanpa Kompromi.</span>
      </h2>

      <div class="mt-14 grid gap-10 md:grid-cols-3">
        {values.map((v) => (
          <div class="border-t-2 border-cream/25 pt-6">
            <span class="font-display-x text-sarang text-3xl tabular leading-none">{v.n}</span>
            <h3 class="font-display-x uppercase text-3xl mt-4 leading-tight">{v.t}</h3>
            <p class="mt-3 text-cream/80 leading-relaxed">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div aria-hidden="true" class="tarp-thin h-3"></div>

  {/* CTA */}
  <section class="bg-sarang text-red-deep">
    <div class="shell px-5 md:px-10 py-14 md:py-20 grid md:grid-cols-12 gap-8 items-end">
      <h2 class="md:col-span-8 font-display-x uppercase leading-[0.86] tracking-[-0.025em]" style="font-size: clamp(2.5rem, 5.5vw, 5.5rem);">
        Mampir, Yuk —<br/>
        <span class="text-charcoal">Atau Pesan Dari Rumah.</span>
      </h2>
      <div class="md:col-span-4 flex flex-col gap-3 items-stretch md:items-end">
        <a href="/lokasi" class="inline-flex items-center justify-center gap-2 bg-charcoal text-cream px-6 py-3.5 text-sm uppercase tracking-[0.18em] font-bold hover:bg-red-deep transition-colors">
          <Icon name="map-pin" size={14}/>
          Lihat Lokasi
        </a>
        <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 border-2 border-charcoal text-charcoal px-6 py-3.5 text-sm uppercase tracking-[0.18em] font-bold hover:bg-charcoal hover:text-cream transition-colors">
          <Icon name="message-circle" size={14}/>
          Pesan via WA
        </a>
      </div>
    </div>
  </section>
</Base>
