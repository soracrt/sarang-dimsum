---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const values = [
  { icon: 'shield-check' as const, t: 'Halal, Selalu',     d: 'Bahan, proses, dapur. Nggak ada kompromi.' },
  { icon: 'wallet'       as const, t: 'Harga Dompetan',    d: 'Mulai dari Rp 14rb. Gak bikin mikir dua kali.' },
  { icon: 'users-round'  as const, t: 'Ramah Keluarga',    d: 'Porsi pas berdua, paket buat seisi rumah.' },
];
---

<Base title="Tentang — Sarang Dimsum" description="Cerita di balik Sarang Dimsum — dapur kecil halal di Tiban, Batam, didirikan oleh Arfan Putra.">
  {/* RED HERO */}
  <section class="bg-red text-cream">
    <div class="mx-auto max-w-7xl px-5 md:px-8 pt-20 md:pt-28 pb-20 md:pb-28">
      <p class="eyebrow text-sarang">Tentang Sarang</p>
      <h1 class="font-display-x text-[4.5rem] sm:text-[6.5rem] md:text-[9rem] mt-4 leading-[0.86] uppercase">
        Dapur Kecil<br/>
        Di Tiban,<br/>
        <span class="text-sarang">Halal Sepenuhnya.</span>
      </h1>
      <p class="mt-10 text-lg md:text-xl text-cream/80 max-w-2xl leading-relaxed">
        Dimsum hangat, banyak varian, harga dompetan — dari satu dapur, satu kompor, satu keyakinan: enak nggak harus mahal.
      </p>
    </div>
  </section>

  {/* CERITA — short, direct, no founder dossier */}
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 md:px-8 py-20 md:py-24">
      <div class="grid md:grid-cols-[auto_1fr] gap-10 md:gap-14 items-start">
        <Arfan pose="wave" class="w-32 md:w-40 h-auto"/>
        <div class="text-lg md:text-xl text-charcoal-soft space-y-6 leading-[1.7]">
          <p>
            Sarang Dimsum dimulai 2024 di Jalan Ciptaland, Tiban. Resep dicoba puluhan kali sampai keluarga sendiri ngangguk-ngangguk.
          </p>
          <p>
            Dimsum bukan cuma makanan — itu cara kumpul, cara cerita. Itu kenapa kami pilih nama <strong class="text-charcoal font-medium">Sarang</strong>: biar tempat ini terasa kayak rumah, bukan kayak restoran.
          </p>
          <p>
            Dan koki kecil yang nongkrong di logo kami — namanya <strong class="text-charcoal font-medium">Arfan</strong>, dipinjem dari nama pemiliknya: <strong class="text-charcoal font-medium">Arfan Putra</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* TIGA JANJI — bold uppercase */}
  <section class="bg-charcoal text-cream">
    <div class="mx-auto max-w-7xl px-5 md:px-8 py-20 md:py-24">
      <p class="eyebrow text-sarang">Yang Kami Pegang</p>
      <h2 class="font-display-x text-5xl md:text-7xl uppercase mt-3 leading-[0.95]">
        Tiga Hal,<br/>
        <span class="text-sarang">Tanpa Kompromi.</span>
      </h2>

      <div class="mt-14 grid gap-10 md:grid-cols-3">
        {values.map((v) => (
          <div class="border-t border-cream/15 pt-6">
            <div class="w-12 h-12 rounded-full bg-cream text-charcoal grid place-items-center">
              <Icon name={v.icon} size={20}/>
            </div>
            <h3 class="font-display-x text-3xl uppercase mt-6">{v.t}</h3>
            <p class="mt-3 text-cream/70 leading-relaxed">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-sarang text-charcoal">
    <div class="mx-auto max-w-7xl px-5 md:px-8 py-12 md:py-16 flex flex-wrap items-center justify-between gap-6">
      <h2 class="font-display-x text-3xl md:text-5xl uppercase leading-[0.95]">
        Mampir, Yuk —<br class="md:hidden"/> Atau Pesan Dari Rumah.
      </h2>
      <div class="flex flex-wrap gap-3">
        <a href="/lokasi" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-7 py-3.5 font-medium hover:bg-red-deep transition-colors">
          <Icon name="map-pin" size={16}/>
          Lihat Lokasi
        </a>
        <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border-2 border-charcoal px-7 py-3.5 font-medium hover:bg-charcoal hover:text-cream transition-colors">
          <Icon name="message-circle" size={16}/>
          Pesan via WhatsApp
        </a>
      </div>
    </div>
  </section>
</Base>
