---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const values = [
  { icon: 'shield-check' as const, t: 'Halal, selalu.',     d: 'Dari bahan, proses, sampai dapur. Nggak ada kompromi soal ini.' },
  { icon: 'wallet'       as const, t: 'Harga dompetan.',    d: 'Dimsum enak nggak harus bikin mikir dua kali. Mulai dari Rp 14rb.' },
  { icon: 'users-round'  as const, t: 'Ramah keluarga.',    d: 'Tempat duduk nyaman, paket buat seisi rumah, layanan yang sopan.' },
];
---

<Base title="Tentang — Sarang Dimsum" description="Cerita di balik Sarang Dimsum dan kenalan sama Arfan, koki maskot kami.">
  <section class="mx-auto max-w-4xl px-5 md:px-8 py-16 md:py-24">
    <p class="eyebrow">Tentang Sarang</p>
    <h1 class="font-display-x text-6xl md:text-8xl mt-4 leading-[0.9]">
      Dapur kecil<br/>di Tiban,<br/>
      <span class="italic font-display normal-case tracking-normal text-charcoal-soft">rumah kedua buat dimsum halal.</span>
    </h1>

    <div class="mt-14 grid md:grid-cols-[1fr_auto] gap-12 items-start">
      <div class="text-lg text-charcoal-soft space-y-6 leading-[1.7]">
        <p>
          Sarang Dimsum lahir dari satu ide sederhana: dimsum enak, halal, dan harganya masuk akal — nggak harus pergi ke mal, nggak harus mahal.
          Kami mulai dari dapur kecil di Jalan Ciptaland, Tiban, Batam, dengan resep yang sudah dicoba puluhan kali sampai keluarga sendiri ngangguk-ngangguk.
        </p>
        <p>
          Buat kami, dimsum bukan cuma makanan. Itu cara kumpul. Cara cerita. Cara nemenin orang yang lagi capek, lagi senang, atau lagi pengen makan enak doang.
          Itu kenapa kami pilih nama <em>Sarang</em> — biar tempat ini terasa kayak rumah, bukan kayak restoran.
        </p>
        <p>
          Dan itu juga kenapa ada <strong class="text-charcoal font-medium">Arfan</strong>, koki kecil yang nongkrong di logo kami. Dia yang sambut kamu di pintu, yang ngasih kode <em>"mampir, yuk"</em> kalau kamu lewat depan steling, yang ketiduran di footer kalau warung sudah tutup.
        </p>
      </div>
      <Arfan pose="wave" class="w-44 h-auto justify-self-center md:justify-self-end" />
    </div>
  </section>

  <section class="bg-cream-soft border-y border-charcoal/8">
    <div class="mx-auto max-w-4xl px-5 md:px-8 py-20">
      <p class="eyebrow">Yang kami pegang</p>
      <h2 class="font-display text-4xl md:text-5xl mt-3 leading-tight">Tiga hal, <em>tanpa kompromi.</em></h2>
      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {values.map((v) => (
          <div>
            <div class="w-11 h-11 rounded-full bg-cream border border-charcoal/15 grid place-items-center text-charcoal">
              <Icon name={v.icon} size={20}/>
            </div>
            <h3 class="font-display text-xl mt-5">{v.t}</h3>
            <p class="mt-2 text-charcoal-mute leading-relaxed">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 md:px-8 py-24 text-center">
    <h2 class="font-display text-4xl md:text-5xl leading-tight">Mampir, <em>yuk.</em></h2>
    <p class="mt-5 text-charcoal-soft text-lg">Datang langsung, atau pesan dulu lewat WhatsApp.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/lokasi" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-7 py-3.5 font-medium hover:bg-charcoal-soft transition-colors">
        <Icon name="map-pin" size={16}/>
        Lihat lokasi
      </a>
      <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-charcoal/20 px-7 py-3.5 font-medium hover:border-charcoal transition-colors">
        <Icon name="message-circle" size={16}/>
        Pesan via WhatsApp
      </a>
    </div>
  </section>
</Base>
