---
import Base from '../layouts/Base.astro';
import Arfan from '../components/Arfan.astro';
import Icon from '../components/Icon.astro';
import { links } from '../lib/links';

const values = [
  { icon: 'shield-check' as const, t: 'Halal, selalu.',     d: 'Dari bahan, proses, sampai dapur. Nggak ada kompromi soal ini.' },
  { icon: 'wallet'       as const, t: 'Harga dompetan.',    d: 'Dimsum enak nggak harus bikin mikir dua kali. Mulai dari Rp 14rb.' },
  { icon: 'users-round'  as const, t: 'Ramah keluarga.',    d: 'Tempat duduk nyaman, paket buat seisi rumah, layanan yang sopan.' },
];
---

<Base title="Tentang — Sarang Dimsum" description="Cerita di balik Sarang Dimsum dari pendirinya, Arfan Putra — dapur kecil halal di Tiban, Batam.">
  {/* HERITAGE BAND */}
  <section class="border-b border-charcoal/10 bg-cream-soft/40">
    <div class="mx-auto max-w-5xl px-5 md:px-8 py-5 flex flex-wrap items-center justify-between gap-4 text-[0.6875rem] tracking-[0.28em] uppercase text-charcoal-mute">
      <span class="inline-flex items-center gap-3">
        <span class="font-display italic normal-case tracking-normal text-charcoal text-base leading-none">Est.</span>
        <span class="tabular">MMXXIV</span>
        <span class="text-charcoal/25">—</span>
        <span>Tiban, Batam</span>
      </span>
      <span>Halaman pendiri</span>
    </div>
  </section>

  {/* TITLE */}
  <section class="mx-auto max-w-4xl px-5 md:px-8 pt-20 md:pt-28">
    <p class="eyebrow">Catatan dari pendiri</p>
    <h1 class="font-display text-5xl md:text-7xl mt-5 leading-[1.02] tracking-[-0.025em]">
      Dapur kecil di Tiban,
      <em class="text-charcoal-mute">dibangun pelan-pelan,</em>
      <br class="hidden md:block"/>
      buat keluarga dulu —
      <em class="text-charcoal-mute">baru kotanya.</em>
    </h1>
  </section>

  {/* FOUNDER INTRO CARD — editorial portrait + dossier */}
  <section class="mx-auto max-w-5xl px-5 md:px-8 mt-16 md:mt-20">
    <div class="grid md:grid-cols-[auto_1fr] gap-8 md:gap-12 items-stretch">
      {/* portrait medallion */}
      <div class="relative w-full max-w-xs md:w-72 mx-auto md:mx-0">
        <div class="aspect-[4/5] rounded-3xl border border-charcoal/12 bg-gradient-to-b from-cream-soft to-cream-deep overflow-hidden relative">
          {/* decorative corner stamps */}
          <span class="absolute top-4 left-4 text-[0.6875rem] tracking-[0.28em] uppercase text-charcoal-mute">Pendiri</span>
          <span class="absolute top-4 right-4 font-display italic text-charcoal-mute text-base">N° 01</span>
          <span class="absolute bottom-4 left-4 text-[0.6875rem] tracking-[0.28em] uppercase text-charcoal-mute tabular">MMXXIV</span>
          <span class="absolute bottom-4 right-4 text-[0.6875rem] tracking-[0.28em] uppercase text-charcoal-mute">Tiban · BTM</span>

          {/* portrait illustration — simplified founder line-portrait */}
          <div class="absolute inset-0 grid place-items-center">
            <svg viewBox="0 0 200 240" class="w-full h-full p-10 text-charcoal" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustrasi potret Arfan Putra">
              {/* warm halo */}
              <circle cx="100" cy="100" r="62" fill="rgba(240, 180, 41, 0.18)"/>
              {/* shoulders / shirt */}
              <path d="M28 230 C 36 184, 70 168, 100 168 C 130 168, 164 184, 172 230 Z" fill="#F1E9D5" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"/>
              {/* collar */}
              <path d="M82 172 L 100 196 L 118 172" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
              {/* neck */}
              <path d="M88 168 V 156 M 112 168 V 156" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
              {/* head */}
              <ellipse cx="100" cy="118" rx="42" ry="48" fill="#FAF6EE" stroke="currentColor" stroke-width="2.5"/>
              {/* hair */}
              <path d="M62 110 C 60 78, 82 60, 100 60 C 122 60, 144 78, 138 112 C 132 96, 118 88, 100 88 C 82 88, 70 96, 62 110 Z" fill="currentColor"/>
              {/* sideburns */}
              <path d="M62 112 C 62 124, 64 132, 68 138" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" fill="none"/>
              <path d="M138 112 C 138 124, 136 132, 132 138" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" fill="none"/>
              {/* brows */}
              <path d="M78 110 C 84 106, 92 106, 96 110" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" fill="none"/>
              <path d="M104 110 C 108 106, 116 106, 122 110" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" fill="none"/>
              {/* eyes */}
              <circle cx="86" cy="120" r="2.2" fill="currentColor"/>
              <circle cx="114" cy="120" r="2.2" fill="currentColor"/>
              {/* nose */}
              <path d="M100 122 C 98 132, 96 138, 100 142 C 102 144, 104 144, 106 142" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
              {/* mouth — calm half-smile */}
              <path d="M88 152 C 94 156, 106 156, 112 152" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" fill="none"/>
              {/* chin shadow hairline */}
              <path d="M76 144 C 84 156, 116 156, 124 144" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.35"/>
            </svg>
          </div>
        </div>

        {/* yellow seal under medallion */}
        <div class="absolute -bottom-3 right-6 w-14 h-14 rounded-full bg-sarang border border-charcoal/20 grid place-items-center text-charcoal shadow-[0_8px_18px_-8px_rgba(20,17,13,0.35)]">
          <Icon name="shield-check" size={20}/>
        </div>
      </div>

      {/* dossier */}
      <div class="flex flex-col justify-between">
        <div>
          <p class="eyebrow">Profil singkat</p>
          <p class="font-display text-4xl md:text-5xl mt-3 leading-tight">Arfan Putra</p>
          <p class="mt-2 text-charcoal-mute">Pendiri · Sarang Dimsum</p>

          <p class="mt-7 text-lg text-charcoal-soft leading-[1.7] max-w-lg">
            Lahir dan besar di Batam. Mulai Sarang Dimsum dari dapur rumah pada 2024, dengan satu keyakinan sederhana: dimsum halal yang enak nggak harus mahal — dan nggak harus jauh.
          </p>
        </div>

        <dl class="mt-10 grid grid-cols-2 sm:grid-cols-3 gap-y-6 gap-x-6 border-t border-charcoal/10 pt-8">
          <div>
            <dt class="eyebrow">Mulai</dt>
            <dd class="font-display text-2xl mt-1.5 tabular">2024</dd>
          </div>
          <div>
            <dt class="eyebrow">Asal</dt>
            <dd class="font-display text-2xl mt-1.5">Tiban, Batam</dd>
          </div>
          <div>
            <dt class="eyebrow">Filosofi</dt>
            <dd class="font-display italic text-xl mt-1.5 leading-snug">"Mampir, yuk."</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  {/* FOUNDER LETTER — editorial two-column */}
  <section class="mx-auto max-w-5xl px-5 md:px-8 mt-16 md:mt-20 pb-24">
    <div class="grid md:grid-cols-[1fr_2fr] gap-10 md:gap-16">
      {/* meta column */}
      <aside class="md:sticky md:top-24 md:self-start space-y-7 md:pr-2 border-l-2 border-sarang/60 pl-6 md:pl-7">
        <div>
          <p class="eyebrow">Pendiri</p>
          <p class="mt-2 font-display text-2xl">Arfan Putra</p>
          <p class="text-charcoal-mute text-sm mt-1">Tiban, Batam</p>
        </div>
        <div>
          <p class="eyebrow">Mulai</p>
          <p class="mt-2 font-display text-2xl tabular">2024</p>
          <p class="text-charcoal-mute text-sm mt-1">Dari dapur rumah, satu kompor.</p>
        </div>
        <div>
          <p class="eyebrow">Yang dipegang</p>
          <p class="mt-2 font-display text-xl italic text-charcoal-soft leading-snug">"Halal, hangat, harga dompetan."</p>
        </div>
      </aside>

      {/* letter body */}
      <article class="text-[1.0625rem] md:text-lg text-charcoal-soft leading-[1.75] space-y-6">
        <p class="first-letter:font-display first-letter:text-7xl first-letter:float-left first-letter:mr-3 first-letter:mt-1 first-letter:leading-[0.85] first-letter:text-charcoal">
          Sarang Dimsum lahir dari satu ide sederhana: dimsum enak, halal, dan harganya masuk akal — nggak harus pergi ke mal, nggak harus mahal. Saya mulai dari dapur kecil di Jalan Ciptaland, Tiban, dengan resep yang dicoba puluhan kali sampai keluarga sendiri ngangguk-ngangguk.
        </p>
        <p>
          Buat saya, dimsum bukan cuma makanan. Itu cara kumpul. Cara cerita. Cara nemenin orang yang lagi capek, lagi senang, atau lagi pengen makan enak doang. Itu kenapa saya pilih nama <em class="text-charcoal">Sarang</em> — biar tempat ini terasa kayak rumah, bukan kayak restoran.
        </p>
        <p>
          Dan itu juga kenapa ada <strong class="text-charcoal font-medium not-italic">Arfan</strong> kecil yang nongkrong di logo kami — koki maskot, namanya saya pinjamkan dari nama saya sendiri. Dia yang sambut kamu di pintu, yang ngasih kode <em>"mampir, yuk"</em> kalau kamu lewat depan steling, yang ketiduran di footer kalau warung sudah tutup.
        </p>
        <p>
          Pelan-pelan, dari satu steling jadi dua. Dari pelanggan tetangga jadi pelanggan satu kota. Tujuannya tetap sama: bikin dimsum halal yang bisa dijangkau siapa aja, di mana aja — dengan rasa yang nggak diturunin.
        </p>
        <p class="text-charcoal">Terima kasih sudah mampir.</p>

        {/* signature block */}
        <div class="pt-8 mt-8 border-t border-charcoal/10 flex items-end gap-6">
          <svg viewBox="0 0 240 80" class="w-44 md:w-52 h-auto text-charcoal" aria-hidden="true">
            <path
              d="M8 52 C 22 28, 38 18, 52 32 C 58 38, 50 56, 36 56 C 24 56, 28 38, 50 36 C 70 34, 86 50, 96 38 C 104 28, 92 22, 86 32 C 80 42, 92 56, 110 50 C 124 45, 128 28, 140 32 C 150 35, 146 50, 134 52 C 124 54, 132 36, 156 36 C 178 36, 188 56, 206 46 C 218 39, 222 24, 232 28"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            />
            <path d="M44 64 C 80 60, 130 60, 200 62" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.55"/>
          </svg>
          <div class="pb-1">
            <p class="font-display text-lg text-charcoal">Arfan Putra</p>
            <p class="text-charcoal-mute text-xs tracking-[0.18em] uppercase mt-1">Pendiri · Sarang Dimsum</p>
          </div>
        </div>
      </article>
    </div>

    <div class="mt-20 flex justify-center">
      <Arfan pose="wave" class="w-32 h-auto opacity-90" />
    </div>
  </section>

  <section class="bg-cream-soft border-y border-charcoal/8">
    <div class="mx-auto max-w-4xl px-5 md:px-8 py-20">
      <p class="eyebrow">Yang kami pegang</p>
      <h2 class="font-display text-4xl md:text-5xl mt-3 leading-tight">Tiga hal, <em>tanpa kompromi.</em></h2>
      <div class="mt-12 grid gap-10 md:grid-cols-3">
        {values.map((v) => (
          <div>
            <div class="w-11 h-11 rounded-full bg-cream border border-charcoal/15 grid place-items-center text-charcoal">
              <Icon name={v.icon} size={20}/>
            </div>
            <h3 class="font-display text-xl mt-5">{v.t}</h3>
            <p class="mt-2 text-charcoal-mute leading-relaxed">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 md:px-8 py-24 text-center">
    <h2 class="font-display text-4xl md:text-5xl leading-tight">Mampir, <em>yuk.</em></h2>
    <p class="mt-5 text-charcoal-soft text-lg">Datang langsung, atau pesan dulu lewat WhatsApp.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/lokasi" class="inline-flex items-center gap-2 rounded-full bg-charcoal text-cream px-7 py-3.5 font-medium hover:bg-charcoal-soft transition-colors">
        <Icon name="map-pin" size={16}/>
        Lihat lokasi
      </a>
      <a href={links.waOrder} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-charcoal/20 px-7 py-3.5 font-medium hover:border-charcoal transition-colors">
        <Icon name="message-circle" size={16}/>
        Pesan via WhatsApp
      </a>
    </div>
  </section>
</Base>
